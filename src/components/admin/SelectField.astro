---
interface Props {
  name: string;
  label: string;
  value?: string;
  required?: boolean;
  placeholder?: string;
  options: { value: string; label: string }[];
  error?: string;
}

const {
  name,
  label,
  value = '',
  required = false,
  placeholder = 'Select...',
  options = [],
  error = '',
} = Astro.props;
---

<div class="form-control">
  <label class="label">
    <span class="label-text">
      {label}{required && <span class="text-error ml-1">*</span>}
    </span>
  </label>
  <select
    id={name}
    name={name}
    class={`select select-bordered w-full ${error ? 'select-error' : ''}`}
    required={required}
  >
    <option value="">{placeholder}</option>
    {
      options.map((opt) => (
        <option value={opt.value} selected={value === opt.value}>
          {opt.label}
        </option>
      ))
    }
  </select>
  {
    error && (
      <span class="text-error text-sm mt-1" data-field={name}>
        {error}
      </span>
    )
  }
</div>
