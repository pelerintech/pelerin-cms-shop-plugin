---
// Admin: create voucher
// Route: /admin/plugins/shop/vouchers/new
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout title="New Voucher" currentPath="/admin/plugins/shop/vouchers" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Vouchers', href: '/admin/plugins/shop/vouchers' },
    { label: 'New Voucher' },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">New Voucher</h1>
      <p class="text-base-content/60">Create a new discount code</p>
    </div>
    <a href="/admin/plugins/shop/vouchers" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="voucher-form" class="space-y-6">
        <div class="space-y-4">
          <TextField name="code" label="Code" required placeholder="SUMMER10" style="text-transform: uppercase;" />
          <SelectField name="type" label="Type" required placeholder="Select type..." options={[
            { value: 'fixed_amount', label: 'Fixed Amount' },
            { value: 'percentage', label: 'Percentage' },
            { value: 'free_shipping', label: 'Free Shipping' },
          ]} />
          <div id="value-field">
            <TextField name="value" label="Value" type="number" step="0.01" min="0" placeholder="10" />
          </div>
          <TextField name="min_order_value" label="Minimum Order Value" type="number" step="0.01" min="0" placeholder="Optional" />
          <TextField name="max_uses" label="Max Uses" type="number" min="1" placeholder="Leave empty for unlimited" />

          <div class="grid grid-cols-2 gap-4">
            <TextField name="valid_from" label="Valid From" type="date" />
            <TextField name="valid_until" label="Valid Until" type="date" />
          </div>

          <CheckboxField name="single_use_per_customer" label="Single use per customer" />
          <CheckboxField name="active" label="Active" checked />
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <a href="/admin/plugins/shop/vouchers" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary" id="save-btn">Create Voucher</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  var API_URL = '/api/plugins/shop/vouchers';

  // Toggle value field visibility based on type
  document.getElementById('type').addEventListener('change', function() {
    var valueField = document.getElementById('value-field');
    if (this.value === 'free_shipping') {
      valueField.style.display = 'none';
    } else {
      valueField.style.display = '';
    }
  });

  document.getElementById('voucher-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var body = {
      code: formData.get('code') || '',
      type: formData.get('type'),
      value: formData.get('type') === 'free_shipping' ? null : (formData.get('value') ? parseFloat(formData.get('value')) : null),
      min_order_value: formData.get('min_order_value') ? parseFloat(formData.get('min_order_value')) : null,
      max_uses: formData.get('max_uses') ? parseInt(formData.get('max_uses')) : null,
      valid_from: formData.get('valid_from') ? new Date(formData.get('valid_from')).toISOString() : null,
      valid_until: formData.get('valid_until') ? new Date(formData.get('valid_until')).toISOString() : null,
      single_use_per_customer: formData.get('single_use_per_customer') === 'on',
      active: formData.get('active') === 'on',
    };

    var errorsEl = document.getElementById('form-error');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Creating...';
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/vouchers';
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to create voucher.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Create Voucher';
    }
  });
</script>
