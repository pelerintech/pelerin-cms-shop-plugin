---
// Admin: vouchers list
// Route: /admin/plugins/shop/vouchers
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { db, vouchers, sql as dbSql } from 'astro:db';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

// Parse query params
const url = new URL(Astro.request.url);
const activeFilter = url.searchParams.get('active') || '';
const typeFilter = url.searchParams.get('type') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;
const offset = (page - 1) * limit;

// Build where clause
const conditions: string[] = [];
if (activeFilter === 'true') {
  conditions.push(`v.active = 1 AND (v.valid_until IS NULL OR v.valid_until >= datetime('now')) AND (v.max_uses IS NULL OR v.uses_count < v.max_uses)`);
} else if (activeFilter === 'false') {
  conditions.push(`(v.active = 0 OR (v.valid_until IS NOT NULL AND v.valid_until < datetime('now')) OR (v.max_uses IS NOT NULL AND v.uses_count >= v.max_uses))`);
}
if (typeFilter) {
  conditions.push(`v.type = '${typeFilter.replace(/'/g, "''")}'`);
}

const whereClause = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';

// Fetch vouchers
const result = await db.run(dbSql`
  SELECT v.*,
    CASE
      WHEN v.active = 0 THEN 'inactive'
      WHEN v.valid_until IS NOT NULL AND v.valid_until < datetime('now') THEN 'expired'
      WHEN v.max_uses IS NOT NULL AND v.uses_count >= v.max_uses THEN 'exhausted'
      ELSE 'active'
    END as status
  FROM ${vouchers} v
  ${dbSql.raw(whereClause)}
  ORDER BY v.created_at DESC
  LIMIT ${limit} OFFSET ${offset}
`);

const voucherList = result.rows as any[];

// Count total
const countResult = await db.run(dbSql`
  SELECT COUNT(*) as total FROM ${vouchers} v
  ${dbSql.raw(whereClause)}
`);
const total = (countResult.rows[0] as any).total as number;
const totalPages = Math.ceil(total / limit);

function statusBadge(status: string) {
  const colors: Record<string, string> = {
    active: 'badge-success',
    inactive: 'badge-ghost',
    expired: 'badge-warning',
    exhausted: 'badge-error',
  };
  return colors[status] || 'badge-ghost';
}

function buildFilterParams(p: number): string {
  const params = new URLSearchParams();
  if (activeFilter) params.set('active', activeFilter);
  if (typeFilter) params.set('type', typeFilter);
  params.set('page', String(p));
  return params.toString();
}
---

<AdminLayout title="Vouchers" currentPath="/admin/plugins/shop/vouchers" user={user}>
  <div class="col-span-12">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">Vouchers</h1>
      <a href="/admin/plugins/shop/vouchers/new" class="btn btn-primary">New Voucher</a>
    </div>

    <!-- Filters -->
    <form method="GET" class="flex gap-4 mb-6 flex-wrap items-end">
      <div class="form-control">
        <label class="label"><span class="label-text">Status</span></label>
        <select name="active" class="select select-bordered">
          <option value="">All</option>
          <option value="true" selected={activeFilter === 'true'}>Active</option>
          <option value="false" selected={activeFilter === 'false'}>Inactive / Expired / Exhausted</option>
        </select>
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text">Type</span></label>
        <select name="type" class="select select-bordered">
          <option value="">All types</option>
          <option value="fixed_amount" selected={typeFilter === 'fixed_amount'}>Fixed Amount</option>
          <option value="percentage" selected={typeFilter === 'percentage'}>Percentage</option>
          <option value="free_shipping" selected={typeFilter === 'free_shipping'}>Free Shipping</option>
        </select>
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text opacity-0">&nbsp;</span></label>
        <button type="submit" class="btn btn-outline">Filter</button>
      </div>
      {(activeFilter || typeFilter) && (
        <div class="form-control">
          <label class="label"><span class="label-text opacity-0">&nbsp;</span></label>
          <a href="/admin/plugins/shop/vouchers" class="btn btn-ghost">Clear</a>
        </div>
      )}
    </form>

    <!-- Voucher Table -->
    {voucherList.length === 0 ? (
      <p class="text-base-content/60">No vouchers found.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Code</th>
              <th>Type</th>
              <th>Value</th>
              <th>Uses</th>
              <th>Max Uses</th>
              <th>Status</th>
              <th>Valid From</th>
              <th>Valid Until</th>
              <th />
            </tr>
          </thead>
          <tbody>
            {voucherList.map((v: any) => (
              <tr>
                <td class="font-mono font-bold">{v.code}</td>
                <td>{v.type === 'fixed_amount' ? 'Fixed Amount' : v.type === 'percentage' ? 'Percentage' : 'Free Shipping'}</td>
                <td class="font-mono">{v.type === 'free_shipping' ? '—' : v.type === 'percentage' ? `${v.value}%` : `${v.value} RON`}</td>
                <td>{v.uses_count}</td>
                <td>{v.max_uses ?? '∞'}</td>
                <td><span class={`badge badge-sm ${statusBadge(v.status)}`}>{v.status}</span></td>
                <td class="text-sm">{v.valid_from ? new Date(v.valid_from).toLocaleDateString() : '—'}</td>
                <td class="text-sm">{v.valid_until ? new Date(v.valid_until).toLocaleDateString() : '—'}</td>
                <td>
                  <div class="flex gap-2">
                    <a href={`/admin/plugins/shop/vouchers/${v.id}?from_page=${page}`} class="btn btn-ghost btn-xs">Edit</a>
                    <button class="btn btn-error btn-xs delete-voucher" data-id={v.id} data-code={v.code}>Delete</button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="join mt-4">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
          <a
            href={`/admin/plugins/shop/vouchers?${buildFilterParams(p)}`}
            class={`join-item btn btn-sm ${p === page ? 'btn-active' : ''}`}
          >
            {p}
          </a>
        ))}
      </div>
    )}
  </div>
</AdminLayout>

<script>
  // Delete voucher
  document.querySelectorAll('.delete-voucher').forEach(btn => {
    btn.addEventListener('click', async () => {
      const voucherId = (btn as HTMLElement).dataset.id!;
      const voucherCode = (btn as HTMLElement).dataset.code!;
      if (!confirm(`Delete voucher "${voucherCode}"?`)) return;
      const res = await fetch(`/api/plugins/shop/vouchers/${voucherId}`, { method: 'DELETE' });
      const result = await res.json();
      if (result.success) location.reload();
      else alert(result.error || 'Failed to delete');
    });
  });
</script>
