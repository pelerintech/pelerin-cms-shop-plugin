---
// Admin: edit voucher
// Route: /admin/plugins/shop/vouchers/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
const { id } = Astro.params;
---

<AdminLayout title="Edit Voucher" currentPath="/admin/plugins/shop/vouchers" user={user}>
  <div class="col-span-12 p-6">
    <div class="flex items-center gap-4 mb-6">
      <a href="/admin/plugins/shop/vouchers" class="btn btn-ghost btn-sm">&larr; Back</a>
      <h1 class="text-2xl font-bold">Edit Voucher</h1>
    </div>

    <div class="mb-4 p-4 bg-base-200 rounded-lg" id="stats-section" style="display:none;">
      <h2 class="text-lg font-semibold mb-2">Usage</h2>
      <div class="grid grid-cols-2 gap-2 text-sm">
        <div><span class="text-gray-500">Uses:</span> <span id="stat-uses">—</span></div>
        <div><span class="text-gray-500">Remaining:</span> <span id="stat-remaining">—</span></div>
        <div><span class="text-gray-500">Status:</span> <span id="stat-status" class="badge badge-sm">—</span></div>
      </div>
    </div>

    <form id="voucher-form" class="space-y-4">
      <div class="form-control">
        <label class="label" for="code"><span class="label-text">Code</span></label>
        <input type="text" id="code" name="code" class="input input-bordered w-full" placeholder="SUMMER10" required style="text-transform: uppercase;" />
      </div>

      <div class="form-control">
        <label class="label" for="type"><span class="label-text">Type</span></label>
        <select id="type" name="type" class="select select-bordered" required>
          <option value="">Select type...</option>
          <option value="fixed_amount">Fixed Amount</option>
          <option value="percentage">Percentage</option>
          <option value="free_shipping">Free Shipping</option>
        </select>
      </div>

      <div class="form-control" id="value-field">
        <label class="label" for="value"><span class="label-text">Value</span></label>
        <input type="number" id="value" name="value" class="input input-bordered w-full" placeholder="10" min="0" step="0.01" />
      </div>

      <div class="form-control">
        <label class="label" for="min_order_value"><span class="label-text">Minimum Order Value</span></label>
        <input type="number" id="min_order_value" name="min_order_value" class="input input-bordered w-full" placeholder="Optional" min="0" step="0.01" />
      </div>

      <div class="form-control">
        <label class="label" for="max_uses"><span class="label-text">Max Uses</span></label>
        <input type="number" id="max_uses" name="max_uses" class="input input-bordered w-full" placeholder="Leave empty for unlimited" min="1" />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="form-control">
          <label class="label" for="valid_from"><span class="label-text">Valid From</span></label>
          <input type="date" id="valid_from" name="valid_from" class="input input-bordered w-full" />
        </div>
        <div class="form-control">
          <label class="label" for="valid_until"><span class="label-text">Valid Until</span></label>
          <input type="date" id="valid_until" name="valid_until" class="input input-bordered w-full" />
        </div>
      </div>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-4">
          <input type="checkbox" id="single_use_per_customer" name="single_use_per_customer" class="checkbox" />
          <span class="label-text">Single use per customer</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-4">
          <input type="checkbox" id="active" name="active" class="checkbox" />
          <span class="label-text">Active</span>
        </label>
      </div>

      <div id="errors" class="hidden alert alert-error"></div>
      <div id="success" class="hidden alert alert-success"></div>

      <div class="form-control mt-6 flex gap-2">
        <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
        <button type="button" class="btn btn-outline btn-error" id="deactivate-btn">Deactivate</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  var VOUCHER_ID = '{id}';
  var API_URL = '/api/plugins/shop/vouchers/' + VOUCHER_ID;

  // Toggle value field based on type
  document.getElementById('type').addEventListener('change', function() {
    var valueField = document.getElementById('value-field');
    if (this.value === 'free_shipping') {
      valueField.style.display = 'none';
    } else {
      valueField.style.display = '';
    }
  });

  // Load existing voucher
  async function loadVoucher() {
    try {
      var res = await fetch(API_URL);
      var json = await res.json();
      if (json.success && json.data) {
        var v = json.data;
        document.getElementById('code').value = v.code || '';
        document.getElementById('type').value = v.type || '';
        document.getElementById('value').value = v.value !== null ? v.value : '';
        document.getElementById('min_order_value').value = v.min_order_value !== null ? v.min_order_value : '';
        document.getElementById('max_uses').value = v.max_uses !== null ? v.max_uses : '';
        if (v.valid_from) {
          document.getElementById('valid_from').value = new Date(v.valid_from).toISOString().split('T')[0];
        }
        if (v.valid_until) {
          document.getElementById('valid_until').value = new Date(v.valid_until).toISOString().split('T')[0];
        }
        document.getElementById('single_use_per_customer').checked = v.single_use_per_customer;
        document.getElementById('active').checked = v.active;

        // Show/hide value field based on type
        if (v.type === 'free_shipping') {
          document.getElementById('value-field').style.display = 'none';
        }

        // Show stats
        document.getElementById('stats-section').style.display = '';
        document.getElementById('stat-uses').textContent = v.uses_count;
        document.getElementById('stat-remaining').textContent = v.remaining_uses !== null ? v.remaining_uses : '∞';
        var statBadge = document.getElementById('stat-status');
        statBadge.textContent = v.status;
        var colors = { active: 'badge-success', inactive: 'badge-ghost', expired: 'badge-warning', exhausted: 'badge-error' };
        statBadge.className = 'badge badge-sm ' + (colors[v.status] || 'badge-ghost');
      } else {
        document.getElementById('errors').classList.remove('hidden');
        document.getElementById('errors').textContent = 'Failed to load voucher.';
      }
    } catch (err) {
      document.getElementById('errors').classList.remove('hidden');
      document.getElementById('errors').textContent = err.message || 'Failed to load.';
    }
  }

  // Submit update
  document.getElementById('voucher-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var body = {
      code: formData.get('code') || undefined,
      type: formData.get('type') || undefined,
      value: document.getElementById('type').value === 'free_shipping' ? null : (formData.get('value') !== '' ? parseFloat(formData.get('value')) : null),
      min_order_value: formData.get('min_order_value') !== '' ? parseFloat(formData.get('min_order_value')) : null,
      max_uses: formData.get('max_uses') !== '' ? parseInt(formData.get('max_uses')) : null,
      valid_from: formData.get('valid_from') ? new Date(formData.get('valid_from') + 'T00:00:00Z').toISOString() : null,
      valid_until: formData.get('valid_until') ? new Date(formData.get('valid_until') + 'T23:59:59Z').toISOString() : null,
      single_use_per_customer: formData.get('single_use_per_customer') === 'on',
      active: formData.get('active') === 'on',
    };

    // Remove undefined fields for partial update
    Object.keys(body).forEach(function(k) { if (body[k] === undefined) delete body[k]; });

    var errorsEl = document.getElementById('errors');
    var successEl = document.getElementById('success');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    errorsEl.classList.add('hidden');
    successEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        successEl.classList.remove('hidden');
        successEl.textContent = 'Voucher updated.';
        setTimeout(function() { successEl.classList.add('hidden'); }, 3000);
        await loadVoucher();
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to update.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });

  // Deactivate button
  document.getElementById('deactivate-btn').addEventListener('click', async function() {
    if (!confirm('Deactivate this voucher? Orders that used this code will not be affected.')) return;

    var errorsEl = document.getElementById('errors');
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, { method: 'DELETE' });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/vouchers';
      } else {
        errorsEl.classList.remove('hidden');
        errorsEl.textContent = json.error || 'Failed to deactivate.';
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    }
  });

  loadVoucher();
</script>