---
// Admin: edit voucher
// Route: /admin/plugins/shop/vouchers/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
const { id } = Astro.params;
const fromPage = new URL(Astro.request.url).searchParams.get('from_page') || '1';
---

<AdminLayout title="Edit Voucher" currentPath="/admin/plugins/shop/vouchers" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Vouchers', href: '/admin/plugins/shop/vouchers' },
    { label: 'Edit Voucher' },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold" id="page-title">Edit Voucher</h1>
      <p class="text-base-content/60" id="page-subtitle">Loading...</p>
    </div>
    <a href="/admin/plugins/shop/vouchers" class="btn btn-ghost">Back</a>
  </div>

  <!-- Stats Section -->
  <div class="card bg-base-200/50 col-span-12 mb-4" id="stats-section" style="display:none;">
    <div class="card-body py-4">
      <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-2">Usage</h4>
      <div class="grid grid-cols-3 gap-4 text-sm">
        <div><span class="text-base-content/60">Uses:</span> <span id="stat-uses">—</span></div>
        <div><span class="text-base-content/60">Remaining:</span> <span id="stat-remaining">—</span></div>
        <div><span class="text-base-content/60">Status:</span> <span id="stat-status" class="badge badge-sm">—</span></div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="voucher-form" class="space-y-6">
        <div class="space-y-4">
          <TextField name="code" label="Code" required placeholder="SUMMER10" style="text-transform: uppercase;" />
          <SelectField name="type" label="Type" required placeholder="Select type..." options={[
            { value: 'fixed_amount', label: 'Fixed Amount' },
            { value: 'percentage', label: 'Percentage' },
            { value: 'free_shipping', label: 'Free Shipping' },
          ]} />
          <div id="value-field">
            <TextField name="value" label="Value" type="number" step="0.01" min="0" placeholder="10" />
          </div>
          <TextField name="min_order_value" label="Minimum Order Value" type="number" step="0.01" min="0" placeholder="Optional" />
          <TextField name="max_uses" label="Max Uses" type="number" min="1" placeholder="Leave empty for unlimited" />

          <div class="grid grid-cols-2 gap-4">
            <TextField name="valid_from" label="Valid From" type="date" />
            <TextField name="valid_until" label="Valid Until" type="date" />
          </div>

          <CheckboxField name="single_use_per_customer" label="Single use per customer" />
          <CheckboxField name="active" label="Active" />
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
          <button type="button" class="btn btn-outline btn-error" id="deactivate-btn">Deactivate</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ id, fromPage }}>
  var VOUCHER_ID = id;
  var API_URL = '/api/plugins/shop/vouchers/' + VOUCHER_ID;
  var FROM_PAGE = fromPage;

  // Toggle value field based on type
  document.getElementById('type').addEventListener('change', function() {
    var valueField = document.getElementById('value-field');
    if (this.value === 'free_shipping') {
      valueField.style.display = 'none';
    } else {
      valueField.style.display = '';
    }
  });

  // Load existing voucher
  async function loadVoucher() {
    try {
      var res = await fetch(API_URL);
      var json = await res.json();
      if (json.success && json.data) {
        var v = json.data;

        // Update page title
        document.getElementById('page-title').textContent = 'Edit: ' + v.code;
        document.getElementById('page-subtitle').textContent = 'Voucher details';

        // Update breadcrumbs
        var breadcrumbLabel = document.querySelectorAll('.breadcrumbs li')[2];
        if (breadcrumbLabel) breadcrumbLabel.textContent = 'Edit: ' + v.code;

        // Populate form fields
        var inputs = document.querySelectorAll('#voucher-form input, #voucher-form select');
        var form = document.getElementById('voucher-form');
        form.code.value = v.code || '';
        form.type.value = v.type || '';
        form.value.value = v.value !== null ? v.value : '';
        form.min_order_value.value = v.min_order_value !== null ? v.min_order_value : '';
        form.max_uses.value = v.max_uses !== null ? v.max_uses : '';
        if (v.valid_from) {
          form.valid_from.value = new Date(v.valid_from).toISOString().split('T')[0];
        }
        if (v.valid_until) {
          form.valid_until.value = new Date(v.valid_until).toISOString().split('T')[0];
        }
        form.single_use_per_customer.checked = v.single_use_per_customer;
        form.active.checked = v.active;

        // Show/hide value field based on type
        if (v.type === 'free_shipping') {
          document.getElementById('value-field').style.display = 'none';
        }

        // Show stats
        document.getElementById('stats-section').style.display = '';
        document.getElementById('stat-uses').textContent = v.uses_count;
        document.getElementById('stat-remaining').textContent = v.remaining_uses !== null ? v.remaining_uses : '∞';
        var statBadge = document.getElementById('stat-status');
        statBadge.textContent = v.status;
        var colors = { active: 'badge-success', inactive: 'badge-ghost', expired: 'badge-warning', exhausted: 'badge-error' };
        statBadge.className = 'badge badge-sm ' + (colors[v.status] || 'badge-ghost');
      } else {
        document.getElementById('form-error').classList.remove('hidden');
        document.getElementById('form-error').textContent = 'Failed to load voucher.';
      }
    } catch (err) {
      document.getElementById('form-error').classList.remove('hidden');
      document.getElementById('form-error').textContent = err.message || 'Failed to load.';
    }
  }

  // Submit update
  document.getElementById('voucher-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var body = {
      code: formData.get('code') || undefined,
      type: formData.get('type') || undefined,
      value: form.type.value === 'free_shipping' ? null : (formData.get('value') !== '' ? parseFloat(formData.get('value')) : null),
      min_order_value: formData.get('min_order_value') !== '' ? parseFloat(formData.get('min_order_value')) : null,
      max_uses: formData.get('max_uses') !== '' ? parseInt(formData.get('max_uses')) : null,
      valid_from: formData.get('valid_from') ? new Date(formData.get('valid_from') + 'T00:00:00Z').toISOString() : null,
      valid_until: formData.get('valid_until') ? new Date(formData.get('valid_until') + 'T23:59:59Z').toISOString() : null,
      single_use_per_customer: formData.get('single_use_per_customer') === 'on',
      active: formData.get('active') === 'on',
    };

    // Remove undefined fields for partial update
    Object.keys(body).forEach(function(k) { if (body[k] === undefined) delete body[k]; });

    var errorsEl = document.getElementById('form-error');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/vouchers?page=' + FROM_PAGE;
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to update.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });

  // Deactivate button
  document.getElementById('deactivate-btn').addEventListener('click', async function() {
    if (!confirm('Deactivate this voucher? Orders that used this code will not be affected.')) return;

    var errorsEl = document.getElementById('form-error');
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, { method: 'DELETE' });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/vouchers?page=' + FROM_PAGE;
      } else {
        errorsEl.classList.remove('hidden');
        errorsEl.textContent = json.error || 'Failed to deactivate.';
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    }
  });

  loadVoucher();
</script>
