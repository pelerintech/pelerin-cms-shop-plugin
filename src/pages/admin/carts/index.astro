---
// Admin: open carts list
// Route: /admin/plugins/shop/carts
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { db, carts, cart_items, products, product_prices, product_variants, sql as dbSql } from 'astro:db';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

// Parse query params
const url = new URL(Astro.request.url);
const abandonedSince = url.searchParams.get('abandoned_since'); // optional — null = all carts
const hoursAgo = abandonedSince ? parseInt(abandonedSince) : null;
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;
const offset = (page - 1) * limit;

// Build query: show all carts by default, or filter by abandoned_since
let whereClause = '';
if (hoursAgo !== null && !isNaN(hoursAgo)) {
  const cutoff = new Date(Date.now() - hoursAgo * 60 * 60 * 1000);
  whereClause = `WHERE c.updated_at < '${cutoff.toISOString()}'`;
}

const result = await db.run(dbSql`
  SELECT 
    c.id, c.session_id, c.user_id, c.applied_voucher_code, c.applied_referral_code,
    c.created_at, c.updated_at,
    COUNT(ci.id) as item_count,
    COALESCE(SUM(ci.quantity), 0) as total_quantity
  FROM ${carts} c
  LEFT JOIN ${cart_items} ci ON ci.cart_id = c.id
  ${dbSql.raw(whereClause)}
  GROUP BY c.id
  ORDER BY c.updated_at DESC
  LIMIT ${limit} OFFSET ${offset}
`);

const cartList = result.rows as any[];

// Count total
const countResult = await db.run(dbSql`
  SELECT COUNT(DISTINCT c.id) as total FROM ${carts} c
  ${dbSql.raw(whereClause)}
`);
const total = (countResult.rows[0] as any).total as number;
const totalPages = Math.ceil(total / limit);

// Compute total value for each cart (simplified: sum gross price of items)
async function getCartValue(cartId: string): Promise<string> {
  try {
    const itemsResult = await db.run(dbSql`
      SELECT ci.product_id, ci.variant_id, ci.quantity, p.vat_rate
      FROM ${cart_items} ci
      LEFT JOIN ${products} p ON p.id = ci.product_id
      WHERE ci.cart_id = ${cartId}
    `);
    const items = itemsResult.rows as any[];
    if (items.length === 0) return '0.00 RON';

    let total = 0;
    for (const item of items) {
      let priceNet = 0;
      if (item.variant_id) {
        const pr = await db.run(dbSql`
          SELECT price_net FROM ${product_prices}
          WHERE ${product_prices.variant_id} = ${item.variant_id}
          AND ${product_prices.currency} = 'RON' LIMIT 1
        `);
        if (pr.rows.length > 0) priceNet = (pr.rows[0] as any).price_net;
      } else if (item.product_id) {
        const pr = await db.run(dbSql`
          SELECT price_net FROM ${product_prices}
          WHERE ${product_prices.product_id} = ${item.product_id}
          AND ${product_prices.variant_id} IS NULL
          AND ${product_prices.currency} = 'RON' LIMIT 1
        `);
        if (pr.rows.length > 0) priceNet = (pr.rows[0] as any).price_net;
      }
      const vat = item.vat_rate ?? 0;
      total += Math.round(priceNet * (1 + vat) * item.quantity * 100) / 100;
    }
    return total.toFixed(2) + ' RON';
  } catch {
    return '—';
  }
}

// Compute values for visible carts
const cartValues = new Map<string, string>();
for (const cart of cartList) {
  cartValues.set(cart.id, await getCartValue(cart.id));
}
---

<AdminLayout title="Open Carts" currentPath="/admin/plugins/shop/carts" user={user}>
  <div class="col-span-12 p-6">
    <h1 class="text-2xl font-bold mb-4">Carts</h1>

    <div class="mb-4 flex gap-2 items-center">
      <label class="text-sm">Show carts inactive for:</label>
      <select class="select select-bordered select-sm" onchange="if(this.value==='all'){location.search=''}else{location.search='?abandoned_since='+this.value}">
        <option value="all" {!abandonedSince ? 'selected' : ''}>All open carts</option>
        <option value="1" {abandonedSince === '1' ? 'selected' : ''}>1 hour</option>
        <option value="6" {abandonedSince === '6' ? 'selected' : ''}>6 hours</option>
        <option value="24" {abandonedSince === '24' ? 'selected' : ''}>24 hours</option>
        <option value="72" {abandonedSince === '72' ? 'selected' : ''}>3 days</option>
        <option value="168" {abandonedSince === '168' ? 'selected' : ''}>7 days</option>
      </select>
    </div>

    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr>
            <th>Cart ID</th>
            <th>User</th>
            <th>Items</th>
            <th>Value</th>
            <th>Voucher</th>
            <th>Referral</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Age</th>
          </tr>
        </thead>
        <tbody>
          {cartList.length === 0 ? (
            <tr>
              <td colspan="9" class="text-center text-gray-500 py-4">No carts found</td>
            </tr>
          ) : (
            cartList.map((cart: any) => {
              const ageMs = Date.now() - new Date(cart.updated_at).getTime();
              const ageHours = Math.floor(ageMs / (1000 * 60 * 60));
              const ageDisplay = ageHours < 24 ? `${ageHours}h` : `${Math.floor(ageHours / 24)}d`;
              return (
                <tr>
                  <td class="font-mono text-xs">{cart.id.slice(0, 8)}...</td>
                  <td>{cart.user_id ? <span class="badge badge-sm">User</span> : <span class="badge badge-sm badge-ghost">Guest</span>}</td>
                  <td>{cart.item_count} item{cart.item_count !== 1 ? 's' : ''} ({cart.total_quantity} qty)</td>
                  <td class="font-mono text-sm">{cartValues.get(cart.id) ?? '—'}</td>
                  <td>{cart.applied_voucher_code || '—'}</td>
                  <td>{cart.applied_referral_code || '—'}</td>
                  <td class="text-sm">{new Date(cart.created_at).toLocaleString()}</td>
                  <td class="text-sm">{new Date(cart.updated_at).toLocaleString()}</td>
                  <td>{ageDisplay}</td>
                </tr>
              );
            })
          )}
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="join mt-4">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => {
          const params = new URLSearchParams();
          if (abandonedSince) params.set('abandoned_since', abandonedSince);
          params.set('page', String(p));
          return (
            <a
              href={`/admin/plugins/shop/carts?${params.toString()}`}
              class={`join-item btn btn-sm ${p === page ? 'btn-active' : ''}`}
            >
              {p}
            </a>
          );
        })}
      </div>
    )}

    <div class="mt-2 text-sm text-gray-500">
      {abandonedSince
        ? `Showing carts last updated more than ${abandonedSince} hour${abandonedSince !== '1' ? 's' : ''} ago.`
        : 'Showing all open carts.'}
    </div>
  </div>
</AdminLayout>