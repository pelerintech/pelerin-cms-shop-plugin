---
// Admin: open carts list
// Route: /admin/plugins/shop/carts
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { listCarts, getCartItemCount, getCartWithItems } from '../../../lib/data/cart';
import { getShopConfig } from '../../../lib/data/settings';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

// Parse query params
const url = new URL(Astro.request.url);
const abandonedSince = url.searchParams.get('abandoned_since'); // optional — null = all carts
const hoursAgo = abandonedSince ? parseInt(abandonedSince) : null;
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;

// Use accessor for paginated list with abandoned_since filter
const result = await listCarts(sdk.db, {
  abandonedSinceHours: hoursAgo ?? undefined,
  page,
  limit,
});
const cartList = (result as any).rows;
const total = (result as any).total;
const totalPages = Math.ceil(total / limit);

// Fetch item counts for visible carts (batched via accessor)
const cartItemCounts = new Map<string, { item_count: number; total_quantity: number }>();
for (const cart of cartList) {
  const counts = await getCartItemCount(sdk.db, cart.id);
  cartItemCounts.set(cart.id, counts);
}

// Compute total value for each cart via accessor (enriched items include price_net + vat_rate)
const shopConfig = await getShopConfig(sdk.db);
const cartValues = new Map<string, string>();
for (const cart of cartList) {
  try {
    const enriched = await getCartWithItems(sdk.db, cart.id, shopConfig.defaultCurrency);
    if (!enriched || enriched.items.length === 0) {
      cartValues.set(cart.id, '0.00 ' + shopConfig.defaultCurrency);
      continue;
    }
    let total = 0;
    for (const item of enriched.items) {
      total += Math.round(item.price_net * (1 + (item.vat_rate ?? 0)) * item.quantity * 100) / 100;
    }
    cartValues.set(cart.id, total.toFixed(2) + ' ' + shopConfig.defaultCurrency);
  } catch {
    cartValues.set(cart.id, '—');
  }
}
---

<AdminLayout title="Open Carts" currentPath="/admin/plugins/shop/carts" user={user}>
  <div class="col-span-12 p-6">
    <h1 class="text-2xl font-bold mb-4">Carts</h1>

    <div class="mb-4 flex gap-2 items-center">
      <label class="text-sm">Show carts inactive for:</label>
      <select id="abandoned-filter" class="select select-bordered select-sm">
        <option value="all" {!abandonedSince ? 'selected' : ''}>All open carts</option>
        <option value="1" {abandonedSince === '1' ? 'selected' : ''}>1 hour</option>
        <option value="6" {abandonedSince === '6' ? 'selected' : ''}>6 hours</option>
        <option value="24" {abandonedSince === '24' ? 'selected' : ''}>24 hours</option>
        <option value="72" {abandonedSince === '72' ? 'selected' : ''}>3 days</option>
        <option value="168" {abandonedSince === '168' ? 'selected' : ''}>7 days</option>
      </select>
    </div>

    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr>
            <th>Cart ID</th>
            <th>User</th>
            <th>Items</th>
            <th>Value</th>
            <th>Voucher</th>
            <th>Referral</th>
            <th>Created</th>
            <th>Updated</th>
            <th>Age</th>
          </tr>
        </thead>
        <tbody>
          {
            cartList.length === 0 ? (
              <tr>
                <td colspan="9" class="text-center text-gray-500 py-4">
                  No carts found
                </td>
              </tr>
            ) : (
              cartList.map((cart: any) => {
                const ageMs = Date.now() - new Date(cart.updated_at).getTime();
                const ageHours = Math.floor(ageMs / (1000 * 60 * 60));
                const ageDisplay = ageHours < 24 ? `${ageHours}h` : `${Math.floor(ageHours / 24)}d`;
                const counts = cartItemCounts.get(cart.id) ?? { item_count: 0, total_quantity: 0 };
                return (
                  <tr>
                    <td class="font-mono text-xs">{cart.id.slice(0, 8)}...</td>
                    <td>
                      {cart.user_id ? (
                        <span class="badge badge-sm">User</span>
                      ) : (
                        <span class="badge badge-sm badge-ghost">Guest</span>
                      )}
                    </td>
                    <td>
                      {counts.item_count} item{counts.item_count !== 1 ? 's' : ''} (
                      {counts.total_quantity} qty)
                    </td>
                    <td class="font-mono text-sm">{cartValues.get(cart.id) ?? '—'}</td>
                    <td>{cart.applied_voucher_code || '—'}</td>
                    <td>{cart.applied_referral_code || '—'}</td>
                    <td class="text-sm">{new Date(cart.created_at).toLocaleString()}</td>
                    <td class="text-sm">{new Date(cart.updated_at).toLocaleString()}</td>
                    <td>{ageDisplay}</td>
                  </tr>
                );
              })
            )
          }
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    {
      totalPages > 1 && (
        <div class="join mt-4">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => {
            const params = new URLSearchParams();
            if (abandonedSince) params.set('abandoned_since', abandonedSince);
            params.set('page', String(p));
            return (
              <a
                href={`/admin/plugins/shop/carts?${params.toString()}`}
                class={`join-item btn btn-sm ${p === page ? 'btn-active' : ''}`}
              >
                {p}
              </a>
            );
          })}
        </div>
      )
    }

    <div class="mt-2 text-sm text-gray-500">
      {
        abandonedSince
          ? `Showing carts last updated more than ${abandonedSince} hour${abandonedSince !== '1' ? 's' : ''} ago.`
          : 'Showing all open carts.'
      }
    </div>
  </div>
</AdminLayout>

<script is:inline>
  const filter = document.getElementById('abandoned-filter');
  filter.addEventListener('change', () => {
    const params = new URLSearchParams();
    if (filter.value !== 'all') {
      params.set('abandoned_since', filter.value);
    }
    location.search = params.toString();
  });
</script>
