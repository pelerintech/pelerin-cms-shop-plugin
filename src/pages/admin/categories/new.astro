---
// Admin: new category form
// Route: /admin/plugins/shop/categories/new
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import TextareaField from '../../../components/admin/TextareaField.astro';
import SearchSelect from '../../../components/admin/SearchSelect.astro';
import { getShopConfig } from '../../../lib/data/settings';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const shopConfig = await getShopConfig(sdk.db);
const locales = shopConfig.locales;
const defaultLocale = shopConfig.defaultLocale;
const otherLocales = locales.filter((l) => !l.isDefault);
const hasLocales = locales.length > 0;
---

<AdminLayout title="New Category" currentPath="/admin/plugins/shop/categories" user={user}>
  <Breadcrumbs
    items={[
      { label: 'Shop', href: '/admin/plugins/shop' },
      { label: 'Categories', href: '/admin/plugins/shop/categories' },
      { label: 'New Category' },
    ]}
  />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">New Category</h1>
      <p class="text-base-content/60">Create a new category</p>
    </div>
    <a href="/admin/plugins/shop/categories" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      {
        !hasLocales && (
          <div class="alert alert-warning mb-4">
            <span>
              No locales configured. Go to{' '}
              <a href="/admin/plugins/shop/settings/general" class="font-bold">
                Settings → General → Locales
              </a>{' '}
              to add locales, then reload this page.
            </span>
          </div>
        )
      }

      <form
        id="category-form"
        class="space-y-6"
        data-default-locale={defaultLocale}
        data-locale-codes={JSON.stringify(otherLocales.map((l) => l.code))}
      >
        <div class="space-y-4">
          <SearchSelect
            name="parent_id"
            label="Parent Category"
            searchUrl="/api/plugins/shop/categories?search={query}"
            itemUrl="/api/plugins/shop/categories/{id}"
            placeholder="Search for a parent category..."
          />
          <TextField name="sort_order" label="Sort Order" type="number" value="0" placeholder="0" />
        </div>

        <!-- Section: Content (locales from settings) -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">
              Content
            </h4>
            <div class="space-y-6">
              <!-- Default locale -->
              <div>
                <h5 class="font-medium text-sm mb-3">{defaultLocale.toUpperCase()} (default)</h5>
                <div class="space-y-4">
                  <TextField
                    name="name"
                    label={`Name (${defaultLocale.toUpperCase()})`}
                    required
                    placeholder="e.g. Electronics"
                  />
                  <TextField
                    name="slug"
                    label={`Slug (${defaultLocale.toUpperCase()})`}
                    required
                    placeholder="e.g. electronics"
                  />
                  <TextareaField
                    name="description"
                    label={`Description (${defaultLocale.toUpperCase()})`}
                    placeholder="Optional description"
                    rows={3}
                  />
                </div>
              </div>

              <!-- Other locales -->
              {
                otherLocales.map((locale) => (
                  <div class="border-t border-base-300 pt-4">
                    <h5 class="font-medium text-sm mb-3">
                      {locale.name} ({locale.code.toUpperCase()})
                    </h5>
                    <div class="space-y-4">
                      <TextField
                        name={`name_${locale.code}`}
                        label={`Name (${locale.code.toUpperCase()})`}
                        placeholder={`e.g. Electronice`}
                      />
                      <TextField
                        name={`slug_${locale.code}`}
                        label={`Slug (${locale.code.toUpperCase()})`}
                        placeholder={`e.g. electronice`}
                      />
                      <TextareaField
                        name={`description_${locale.code}`}
                        label={`Description (${locale.code.toUpperCase()})`}
                        placeholder="Optional description"
                        rows={3}
                      />
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <a href="/admin/plugins/shop/categories" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary">Create Category</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  document.getElementById('category-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const data: Record<string, any> = {
      name: fd.get('name'),
      slug: fd.get('slug'),
      description: fd.get('description') || null,
      parent_id: fd.get('parent_id') || null,
      sort_order: parseInt(fd.get('sort_order') as string) || 0,
    };

    // Include all locale fields (name_en, slug_en, description_en, etc.)
    const localeCodes: string[] = JSON.parse(form.dataset.localeCodes || '[]');
    for (const loc of localeCodes) {
      const nameVal = fd.get(`name_${loc}`);
      const slugVal = fd.get(`slug_${loc}`);
      const descVal = fd.get(`description_${loc}`);
      if (nameVal) data[`name_${loc}`] = nameVal;
      if (slugVal) data[`slug_${loc}`] = slugVal;
      if (descVal) data[`description_${loc}`] = descVal;
    }

    const res = await fetch('/api/plugins/shop/categories', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const result = await res.json();
    if (result.success) {
      window.location.href = '/admin/plugins/shop/categories';
    } else {
      const err = document.getElementById('form-error')!;
      err.textContent = result.error || 'Failed to create category';
      err.classList.remove('hidden');

      // Show field-level errors
      if (result.fields) {
        for (const [field, message] of Object.entries(result.fields as Record<string, string>)) {
          const span = document.querySelector(`[data-field="${field}"]`);
          if (span) {
            span.textContent = message;
            span.classList.remove('hidden');
          }
        }
      }
    }
  });
</script>
