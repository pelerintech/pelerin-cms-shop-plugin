---
// Admin: edit category form
// Route: /admin/plugins/shop/categories/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import TextareaField from '../../../components/admin/TextareaField.astro';
import { getCategoryById, listCategories, listTranslations } from '../../../lib/data/products';
import { getShopConfig } from '../../../lib/data/settings';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const { id } = Astro.params;
const fromPage = new URL(Astro.request.url).searchParams.get('from_page') || '1';

const shopConfig = await getShopConfig(sdk.db);
const locales = shopConfig.locales;
const defaultLocale = shopConfig.defaultLocale;
const otherLocales = locales.filter(l => !l.isDefault);
const hasLocales = locales.length > 0;

// Fetch category via accessor
const category = await getCategoryById(sdk.db, id);
if (!category) {
  return Astro.redirect('/admin/plugins/shop/categories');
}

// Fetch all categories for parent dropdown
const allCats = await listCategories(sdk.db, defaultLocale);
const parentOptions = allCats
  .filter(c => c.id !== id) // exclude self
  .map(c => ({ value: c.id, label: c.name }));

// Fetch translations via accessor
const transRows = await listTranslations(sdk.db, 'category', id);

// Map existing translations by locale
const translationByLocale: Record<string, any> = {};
for (const t of transRows as any[]) {
  translationByLocale[t.locale] = t;
}
---

<AdminLayout title={`Edit: ${category.name}`} currentPath="/admin/plugins/shop/categories" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Categories', href: '/admin/plugins/shop/categories' },
    { label: `Edit: ${category.name}` },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">Edit: {category.name}</h1>
      <p class="text-base-content/60">ID: {id}</p>
    </div>
    <a href="/admin/plugins/shop/categories" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      {!hasLocales && (
        <div class="alert alert-warning mb-4">
          <span>No locales configured. Go to <a href="/admin/plugins/shop/settings/general" class="font-bold">Settings → General → Locales</a> to add locales, then reload this page.</span>
        </div>
      )}

      <form id="category-form" class="space-y-6" data-default-locale={defaultLocale} data-locale-codes={JSON.stringify(otherLocales.map(l => l.code))}>
        <div class="space-y-4">
          <TextField name="parent_id" label="Parent Category" value={category.parent_id || ''} placeholder="None (top-level)" options={parentOptions} />
          <TextField name="sort_order" label="Sort Order" type="number" value={String(category.sort_order)} placeholder="0" />
        </div>

        <!-- Section: Content (locales from settings) -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Content</h4>
            <div class="space-y-6">

              <!-- Default locale -->
              <div>
                <h5 class="font-medium text-sm mb-3">{defaultLocale.toUpperCase()} (default)</h5>
                <div class="space-y-4">
                  <TextField name="name" label={`Name (${defaultLocale.toUpperCase()})`} value={category.name} required />
                  <TextField name="slug" label={`Slug (${defaultLocale.toUpperCase()})`} value={category.slug} required />
                  <TextareaField name="description" label={`Description (${defaultLocale.toUpperCase()})`} value={category.description || ''} placeholder="Optional description" rows={3} />
                </div>
              </div>

              <!-- Other locales -->
              {otherLocales.map(locale => {
                const t = translationByLocale[locale.code];
                return (
                  <div class="border-t border-base-300 pt-4">
                    <h5 class="font-medium text-sm mb-3">{locale.name} ({locale.code.toUpperCase()})</h5>
                    <div class="space-y-4">
                      <TextField name={`name_${locale.code}`} label={`Name (${locale.code.toUpperCase()})`} value={t?.name || ''} />
                      <TextField name={`slug_${locale.code}`} label={`Slug (${locale.code.toUpperCase()})`} value={t?.slug || ''} />
                      <TextareaField name={`description_${locale.code}`} label={`Description (${locale.code.toUpperCase()})`} value={t?.description || ''} placeholder="Optional description" rows={3} />
                    </div>
                  </div>
                );
              })}

            </div>
          </div>
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  const fromPage = new URLSearchParams(window.location.search).get('from_page') || '1';

  document.getElementById('category-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const fd = new FormData(form);
    const data: Record<string, any> = {
      name: fd.get('name'),
      slug: fd.get('slug'),
      description: fd.get('description') || null,
      parent_id: fd.get('parent_id') || null,
      sort_order: parseInt(fd.get('sort_order') as string) || 0,
    };

    // Include all locale fields (name_en, slug_en, description_en, etc.)
    const localeCodes: string[] = JSON.parse(form.dataset.localeCodes || '[]');
    for (const loc of localeCodes) {
      const nameVal = fd.get(`name_${loc}`);
      const slugVal = fd.get(`slug_${loc}`);
      const descVal = fd.get(`description_${loc}`);
      if (nameVal) data[`name_${loc}`] = nameVal;
      if (slugVal) data[`slug_${loc}`] = slugVal;
      if (descVal) data[`description_${loc}`] = descVal;
    }

    const id = window.location.pathname.split('/').pop();
    const res = await fetch(`/api/plugins/shop/categories/${id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const result = await res.json();
    if (result.success) {
      window.location.href = `/admin/plugins/shop/categories?page=${fromPage}`;
    } else {
      const err = document.getElementById('form-error')!;
      err.textContent = result.error || 'Failed to update category';
      err.classList.remove('hidden');

      // Show field-level errors
      if (result.fields) {
        for (const [field, message] of Object.entries(result.fields as Record<string, string>)) {
          const span = document.querySelector(`[data-field="${field}"]`);
          if (span) {
            span.textContent = message;
            span.classList.remove('hidden');
          }
        }
      }
    }
  });
</script>
