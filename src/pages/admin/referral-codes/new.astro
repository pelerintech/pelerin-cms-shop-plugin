---
// Admin: create referral code
// Route: /admin/plugins/shop/referral-codes/new
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';
import TextareaField from '../../../components/admin/TextareaField.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout title="New Referral Code" currentPath="/admin/plugins/shop/referral-codes" user={user}>
  <Breadcrumbs
    items={[
      { label: 'Shop', href: '/admin/plugins/shop' },
      { label: 'Referral Codes', href: '/admin/plugins/shop/referral-codes' },
      { label: 'New Referral Code' },
    ]}
  />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">New Referral Code</h1>
      <p class="text-base-content/60">Create a new partner referral code</p>
    </div>
    <a href="/admin/plugins/shop/referral-codes" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="referral-form" class="space-y-6">
        <div class="space-y-4">
          <TextField
            name="code"
            label="Code"
            required
            placeholder="DR-IONESCU"
            style="text-transform: uppercase;"
          />
          <TextField name="name" label="Partner Name" required placeholder="Dr. Ionescu Cabinet" />
          <SelectField
            name="discount_type"
            label="Discount Type"
            placeholder="None"
            options={[
              { value: 'fixed_amount', label: 'Fixed Amount' },
              { value: 'percentage', label: 'Percentage' },
            ]}
          />
          <div id="discount-value-field" style="display:none;">
            <TextField
              name="discount_value"
              label="Discount Value"
              type="number"
              step="0.01"
              min="0"
              placeholder="10"
            />
          </div>
          <TextareaField
            name="notes"
            label="Notes"
            placeholder="Optional notes about this referral partner"
            rows={3}
          />
          <CheckboxField name="active" label="Active" checked />
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <a href="/admin/plugins/shop/referral-codes" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary" id="save-btn">Create Referral Code</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  var API_URL = '/api/plugins/shop/referral-codes';

  // Toggle discount value visibility
  document.getElementById('discount_type').addEventListener('change', function () {
    var valueField = document.getElementById('discount-value-field');
    if (this.value) {
      valueField.style.display = '';
    } else {
      valueField.style.display = 'none';
      var dv = document.getElementById('discount_value');
      if (dv) dv.value = '';
    }
  });

  document.getElementById('referral-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var discountType = formData.get('discount_type') || null;
    var body = {
      code: formData.get('code') || '',
      name: formData.get('name') || '',
      discount_type: discountType,
      discount_value: discountType
        ? formData.get('discount_value')
          ? parseFloat(formData.get('discount_value'))
          : null
        : null,
      notes: formData.get('notes') || null,
      active: formData.get('active') === 'on',
    };

    var errorsEl = document.getElementById('form-error');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Creating...';
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/referral-codes';
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to create referral code.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Create Referral Code';
    }
  });
</script>
