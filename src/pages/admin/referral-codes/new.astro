---
// Admin: create referral code
// Route: /admin/plugins/shop/referral-codes/new
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout title="New Referral Code" currentPath="/admin/plugins/shop/referral-codes" user={user}>
  <div class="col-span-12 p-6">
    <div class="flex items-center gap-4 mb-6">
      <a href="/admin/plugins/shop/referral-codes" class="btn btn-ghost btn-sm">&larr; Back</a>
      <h1 class="text-2xl font-bold">New Referral Code</h1>
    </div>

    <form id="referral-form" class="space-y-4">
      <div class="form-control">
        <label class="label" for="code"><span class="label-text">Code</span></label>
        <input type="text" id="code" name="code" class="input input-bordered w-full" placeholder="DR-IONESCU" required style="text-transform: uppercase;" />
      </div>

      <div class="form-control">
        <label class="label" for="name"><span class="label-text">Partner Name</span></label>
        <input type="text" id="name" name="name" class="input input-bordered w-full" placeholder="Dr. Ionescu Cabinet" required />
      </div>

      <div class="form-control">
        <label class="label" for="discount_type"><span class="label-text">Discount Type</span></label>
        <select id="discount_type" name="discount_type" class="select select-bordered">
          <option value="">None</option>
          <option value="fixed_amount">Fixed Amount</option>
          <option value="percentage">Percentage</option>
        </select>
      </div>

      <div class="form-control" id="discount-value-field" style="display:none;">
        <label class="label" for="discount_value"><span class="label-text">Discount Value</span></label>
        <input type="number" id="discount_value" name="discount_value" class="input input-bordered w-full" placeholder="10" min="0" step="0.01" />
      </div>

      <div class="form-control">
        <label class="label" for="notes"><span class="label-text">Notes</span></label>
        <textarea id="notes" name="notes" class="textarea textarea-bordered w-full" placeholder="Optional notes about this referral partner" rows="3"></textarea>
      </div>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-4">
          <input type="checkbox" id="active" name="active" class="checkbox" checked />
          <span class="label-text">Active</span>
        </label>
      </div>

      <div id="errors" class="hidden alert alert-error"></div>

      <div class="form-control mt-6">
        <button type="submit" class="btn btn-primary" id="save-btn">Create Referral Code</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  var API_URL = '/api/plugins/shop/referral-codes';

  // Toggle discount value visibility
  document.getElementById('discount_type').addEventListener('change', function() {
    var valueField = document.getElementById('discount-value-field');
    if (this.value) {
      valueField.style.display = '';
    } else {
      valueField.style.display = 'none';
      document.getElementById('discount_value').value = '';
    }
  });

  document.getElementById('referral-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var discountType = formData.get('discount_type') || null;
    var body = {
      code: formData.get('code') || '',
      name: formData.get('name') || '',
      discount_type: discountType,
      discount_value: discountType ? (formData.get('discount_value') ? parseFloat(formData.get('discount_value')) : null) : null,
      notes: formData.get('notes') || null,
      active: formData.get('active') === 'on',
    };

    var errorsEl = document.getElementById('errors');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Creating...';
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/referral-codes';
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to create referral code.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Create Referral Code';
    }
  });
</script>
