---
// Admin: edit referral code
// Route: /admin/plugins/shop/referral-codes/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';
import TextareaField from '../../../components/admin/TextareaField.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
const { id } = Astro.params;
const fromPage = new URL(Astro.request.url).searchParams.get('from_page') || '1';
---

<AdminLayout title="Edit Referral Code" currentPath="/admin/plugins/shop/referral-codes" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Referral Codes', href: '/admin/plugins/shop/referral-codes' },
    { label: 'Edit Referral Code' },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold" id="page-title">Edit Referral Code</h1>
      <p class="text-base-content/60" id="page-subtitle">Loading...</p>
    </div>
    <a href="/admin/plugins/shop/referral-codes" class="btn btn-ghost">Back</a>
  </div>

  <!-- Stats Section -->
  <div class="card bg-base-200/50 col-span-12 mb-4" id="stats-section" style="display:none;">
    <div class="card-body py-4">
      <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-2">Attribution Stats</h4>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div><span class="text-base-content/60">Attributed Orders:</span> <span id="stat-orders">—</span></div>
        <div><span class="text-base-content/60">Attributed Revenue:</span> <span id="stat-revenue">—</span></div>
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="referral-form" class="space-y-6">
        <div class="space-y-4">
          <TextField name="code" label="Code" required placeholder="DR-IONESCU" style="text-transform: uppercase;" />
          <TextField name="name" label="Partner Name" required placeholder="Dr. Ionescu Cabinet" />
          <SelectField name="discount_type" label="Discount Type" placeholder="None" options={[
            { value: 'fixed_amount', label: 'Fixed Amount' },
            { value: 'percentage', label: 'Percentage' },
          ]} />
          <div id="discount-value-field" style="display:none;">
            <TextField name="discount_value" label="Discount Value" type="number" step="0.01" min="0" placeholder="10" />
          </div>
          <TextareaField name="notes" label="Notes" placeholder="Optional notes about this referral partner" rows={3} />
          <CheckboxField name="active" label="Active" />
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
          <button type="button" class="btn btn-outline btn-error" id="deactivate-btn">Deactivate</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script define:vars={{ id, fromPage }}>
  var CODE_ID = id;
  var API_URL = '/api/plugins/shop/referral-codes/' + CODE_ID;
  var FROM_PAGE = fromPage;

  // Toggle discount value visibility
  document.getElementById('discount_type').addEventListener('change', function() {
    var valueField = document.getElementById('discount-value-field');
    if (this.value) {
      valueField.style.display = '';
    } else {
      valueField.style.display = 'none';
    }
  });

  // Load existing referral code
  async function loadCode() {
    try {
      var res = await fetch(API_URL);
      var json = await res.json();
      if (json.success && json.data) {
        var c = json.data;

        // Update page title
        document.getElementById('page-title').textContent = 'Edit: ' + c.code;
        document.getElementById('page-subtitle').textContent = 'Referral code details';

        // Update breadcrumbs
        var breadcrumbLabel = document.querySelectorAll('.breadcrumbs li')[2];
        if (breadcrumbLabel) breadcrumbLabel.textContent = 'Edit: ' + c.code;

        // Populate form fields
        var form = document.getElementById('referral-form');
        form.code.value = c.code || '';
        form.name.value = c.name || '';
        form.discount_type.value = c.discount_type || '';
        form.discount_value.value = c.discount_value !== null ? c.discount_value : '';
        form.notes.value = c.notes || '';
        form.active.checked = c.active;

        // Show discount value if type set
        if (c.discount_type) {
          document.getElementById('discount-value-field').style.display = '';
        }

        // Show stats
        if (c.stats) {
          document.getElementById('stats-section').style.display = '';
          document.getElementById('stat-orders').textContent = c.stats.total_orders;
          document.getElementById('stat-revenue').textContent = c.stats.total_revenue.toFixed(2) + ' ' + (c.stats.currency || '');
        }
      } else {
        document.getElementById('form-error').classList.remove('hidden');
        document.getElementById('form-error').textContent = 'Failed to load referral code.';
      }
    } catch (err) {
      document.getElementById('form-error').classList.remove('hidden');
      document.getElementById('form-error').textContent = err.message || 'Failed to load.';
    }
  }

  // Submit update
  document.getElementById('referral-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var discountType = formData.get('discount_type') || null;
    var body = {
      code: formData.get('code') || undefined,
      name: formData.get('name') || undefined,
      discount_type: discountType !== null ? discountType : undefined,
      discount_value: discountType ? (formData.get('discount_value') !== '' ? parseFloat(formData.get('discount_value')) : null) : null,
      notes: formData.get('notes') || undefined,
      active: formData.get('active') === 'on',
    };

    // Clean undefined
    Object.keys(body).forEach(function(k) {
      if (body[k] === undefined) delete body[k];
    });
    // If discount_type set to empty string (None), explicitly null the value
    if (body.discount_type === undefined) {
      body.discount_type = null;
      body.discount_value = null;
    }

    var errorsEl = document.getElementById('form-error');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/referral-codes?page=' + FROM_PAGE;
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to update.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });

  // Deactivate button
  document.getElementById('deactivate-btn').addEventListener('click', async function() {
    if (!confirm('Deactivate this referral code? Existing orders will retain the code value.')) return;

    var errorsEl = document.getElementById('form-error');
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, { method: 'DELETE' });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/referral-codes?page=' + FROM_PAGE;
      } else {
        errorsEl.classList.remove('hidden');
        errorsEl.textContent = json.error || 'Failed to deactivate.';
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    }
  });

  loadCode();
</script>
