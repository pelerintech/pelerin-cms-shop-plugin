---
// Admin: edit referral code
// Route: /admin/plugins/shop/referral-codes/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
const { id } = Astro.params;
---

<AdminLayout title="Edit Referral Code" currentPath="/admin/plugins/shop/referral-codes" user={user}>
  <div class="col-span-12 p-6">
    <div class="flex items-center gap-4 mb-6">
      <a href="/admin/plugins/shop/referral-codes" class="btn btn-ghost btn-sm">&larr; Back</a>
      <h1 class="text-2xl font-bold">Edit Referral Code</h1>
    </div>

    <div class="mb-4 p-4 bg-base-200 rounded-lg" id="stats-section" style="display:none;">
      <h2 class="text-lg font-semibold mb-2">Attribution Stats</h2>
      <div class="grid grid-cols-2 gap-2 text-sm">
        <div><span class="text-gray-500">Attributed Orders:</span> <span id="stat-orders">—</span></div>
        <div><span class="text-gray-500">Attributed Revenue:</span> <span id="stat-revenue">—</span></div>
      </div>
    </div>

    <form id="referral-form" class="space-y-4">
      <div class="form-control">
        <label class="label" for="code"><span class="label-text">Code</span></label>
        <input type="text" id="code" name="code" class="input input-bordered w-full" placeholder="DR-IONESCU" required style="text-transform: uppercase;" />
      </div>

      <div class="form-control">
        <label class="label" for="name"><span class="label-text">Partner Name</span></label>
        <input type="text" id="name" name="name" class="input input-bordered w-full" placeholder="Dr. Ionescu Cabinet" required />
      </div>

      <div class="form-control">
        <label class="label" for="discount_type"><span class="label-text">Discount Type</span></label>
        <select id="discount_type" name="discount_type" class="select select-bordered">
          <option value="">None</option>
          <option value="fixed_amount">Fixed Amount</option>
          <option value="percentage">Percentage</option>
        </select>
      </div>

      <div class="form-control" id="discount-value-field" style="display:none;">
        <label class="label" for="discount_value"><span class="label-text">Discount Value</span></label>
        <input type="number" id="discount_value" name="discount_value" class="input input-bordered w-full" placeholder="10" min="0" step="0.01" />
      </div>

      <div class="form-control">
        <label class="label" for="notes"><span class="label-text">Notes</span></label>
        <textarea id="notes" name="notes" class="textarea textarea-bordered w-full" placeholder="Optional notes about this referral partner" rows="3"></textarea>
      </div>

      <div class="form-control">
        <label class="label cursor-pointer justify-start gap-4">
          <input type="checkbox" id="active" name="active" class="checkbox" />
          <span class="label-text">Active</span>
        </label>
      </div>

      <div id="errors" class="hidden alert alert-error"></div>
      <div id="success" class="hidden alert alert-success"></div>

      <div class="form-control mt-6 flex gap-2">
        <button type="submit" class="btn btn-primary" id="save-btn">Save Changes</button>
        <button type="button" class="btn btn-outline btn-error" id="deactivate-btn">Deactivate</button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  var CODE_ID = '{id}';
  var API_URL = '/api/plugins/shop/referral-codes/' + CODE_ID;

  // Toggle discount value visibility
  document.getElementById('discount_type').addEventListener('change', function() {
    var valueField = document.getElementById('discount-value-field');
    if (this.value) {
      valueField.style.display = '';
    } else {
      valueField.style.display = 'none';
      document.getElementById('discount_value').value = '';
    }
  });

  // Load existing referral code
  async function loadCode() {
    try {
      var res = await fetch(API_URL);
      var json = await res.json();
      if (json.success && json.data) {
        var c = json.data;
        document.getElementById('code').value = c.code || '';
        document.getElementById('name').value = c.name || '';
        document.getElementById('discount_type').value = c.discount_type || '';
        document.getElementById('discount_value').value = c.discount_value !== null ? c.discount_value : '';
        document.getElementById('notes').value = c.notes || '';
        document.getElementById('active').checked = c.active;

        // Show discount value if type set
        if (c.discount_type) {
          document.getElementById('discount-value-field').style.display = '';
        }

        // Show stats
        if (c.stats) {
          document.getElementById('stats-section').style.display = '';
          document.getElementById('stat-orders').textContent = c.stats.total_orders;
          document.getElementById('stat-revenue').textContent = c.stats.total_revenue.toFixed(2) + ' ' + (c.stats.currency || 'RON');
        }
      } else {
        document.getElementById('errors').classList.remove('hidden');
        document.getElementById('errors').textContent = 'Failed to load referral code.';
      }
    } catch (err) {
      document.getElementById('errors').classList.remove('hidden');
      document.getElementById('errors').textContent = err.message || 'Failed to load.';
    }
  }

  // Submit update
  document.getElementById('referral-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);

    var discountType = formData.get('discount_type') || null;
    var body = {
      code: formData.get('code') || undefined,
      name: formData.get('name') || undefined,
      discount_type: discountType !== null ? discountType : undefined,
      discount_value: discountType ? (formData.get('discount_value') !== '' ? parseFloat(formData.get('discount_value')) : null) : null,
      notes: formData.get('notes') || undefined,
      active: formData.get('active') === 'on',
    };

    // Clean undefined
    Object.keys(body).forEach(function(k) {
      if (body[k] === undefined) delete body[k];
    });
    // If discount_type set to empty string (None), explicitly null the value
    if (body.discount_type === undefined) {
      body.discount_type = null;
      body.discount_value = null;
    }

    var errorsEl = document.getElementById('errors');
    var successEl = document.getElementById('success');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    errorsEl.classList.add('hidden');
    successEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      var json = await res.json();
      if (json.success) {
        successEl.classList.remove('hidden');
        successEl.textContent = 'Referral code updated.';
        setTimeout(function() { successEl.classList.add('hidden'); }, 3000);
        await loadCode();
      } else {
        errorsEl.classList.remove('hidden');
        if (json.fields) {
          var msgs = [];
          for (var key in json.fields) {
            msgs.push(key + ': ' + json.fields[key]);
          }
          errorsEl.textContent = msgs.join(' / ');
        } else {
          errorsEl.textContent = json.error || 'Failed to update.';
        }
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Changes';
    }
  });

  // Deactivate button
  document.getElementById('deactivate-btn').addEventListener('click', async function() {
    if (!confirm('Deactivate this referral code? Existing orders will retain the code value.')) return;

    var errorsEl = document.getElementById('errors');
    errorsEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, { method: 'DELETE' });
      var json = await res.json();
      if (json.success) {
        window.location.href = '/admin/plugins/shop/referral-codes';
      } else {
        errorsEl.classList.remove('hidden');
        errorsEl.textContent = json.error || 'Failed to deactivate.';
      }
    } catch (err) {
      errorsEl.classList.remove('hidden');
      errorsEl.textContent = err.message || 'Network error.';
    }
  });

  loadCode();
</script>