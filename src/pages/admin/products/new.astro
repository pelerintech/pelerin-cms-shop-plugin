---
// Admin: new product form
// Route: /admin/plugins/shop/products/new
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { listCategories } from '../../../lib/data/products';
import { getShopConfig } from '../../../lib/data/settings';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';
import RichTextEditor from '../../../components/admin/RichTextEditor.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const catList = await listCategories(sdk.db, 'ro');
const catOptions = catList.map(c => ({ value: c.id, label: c.name }));

// Fetch locales from settings via accessor
const shopConfig = await getShopConfig(sdk.db);
const defaultLocale = shopConfig.defaultLocale;
const otherLocales = shopConfig.locales.filter(l => !l.isDefault);
---

<AdminLayout title="New Product" currentPath="/admin/plugins/shop/products" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Products', href: '/admin/plugins/shop/products' },
    { label: 'New Product' },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">New Product</h1>
      <p class="text-base-content/60">Create a new product</p>
    </div>
    <a href="/admin/plugins/shop/products" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="product-form" class="space-y-6" data-default-locale={defaultLocale} data-locale-codes={JSON.stringify(otherLocales.map(l => l.code))}>

        <!-- Section: General -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">General</h4>
            <div class="space-y-4">
              <TextField name="sku" label="SKU" placeholder="PROD-001" />
              <div class="grid grid-cols-2 gap-4">
                <SelectField name="type" label="Type" required options={[
                  { value: 'physical', label: 'Physical' },
                  { value: 'digital', label: 'Digital' },
                ]} />
                <SelectField name="category_id" label="Category" placeholder="None" options={catOptions} />
              </div>
              <div class="grid grid-cols-2 gap-4">
                <TextField name="vat_rate" label="VAT Rate" type="number" step="0.01" min="0" max="1" placeholder="0.19" />
                <TextField name="stock" label="Stock" type="number" min="0" placeholder="100" />
              </div>
              <CheckboxField name="active" label="Active (visible in store)" checked={true} />
            </div>
          </div>
        </div>

        <!-- Section: Content -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Content</h4>
            <div class="space-y-6">
              <!-- Default locale -->
              <div>
                <h5 class="font-medium text-sm mb-3">{defaultLocale.toUpperCase()} (default)</h5>
                <div class="space-y-4">
                  <TextField name="name" label={`Name (${defaultLocale.toUpperCase()})`} required placeholder="Product name" />
                  <TextField name="slug" label={`Slug (${defaultLocale.toUpperCase()})`} required placeholder="product-slug" />
                  <RichTextEditor name="description" label={`Description (${defaultLocale.toUpperCase()})`} />
                </div>
              </div>

              <!-- Other locales -->
              {otherLocales.map(locale => (
                <div class="border-t border-base-300 pt-4">
                  <h5 class="font-medium text-sm mb-3">{locale.name} ({locale.code.toUpperCase()})</h5>
                  <div class="space-y-4">
                    <TextField name={`name_${locale.code}`} label={`Name (${locale.code.toUpperCase()})`} placeholder={`Product name in ${locale.name}`} />
                    <TextField name={`slug_${locale.code}`} label={`Slug (${locale.code.toUpperCase()})`} placeholder={`product-slug-${locale.code}`} />
                    <RichTextEditor name={`description_${locale.code}`} label={`Description (${locale.code.toUpperCase()})`} />
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <a href="/admin/plugins/shop/products" class="btn btn-ghost">Cancel</a>
          <button type="submit" class="btn btn-primary">Create Product</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  const form = document.getElementById('product-form') as HTMLFormElement;
  const errorDiv = document.getElementById('form-error') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');

    const formData = new FormData(form);
    const data: Record<string, any> = {
      name: formData.get('name'),
      slug: formData.get('slug'),
      sku: formData.get('sku') || null,
      description: formData.get('description') || null,
      type: formData.get('type'),
      category_id: formData.get('category_id') || null,
      vat_rate: formData.get('vat_rate') ? parseFloat(formData.get('vat_rate') as string) : null,
      stock: formData.get('stock') ? parseInt(formData.get('stock') as string) : null,
      active: formData.get('active') === 'on',
      default_locale: document.getElementById('product-form')?.dataset?.defaultLocale || 'ro',
    };

    // Include all locale fields (name_en, slug_en, description_en, etc.)
    const localeCodes: string[] = JSON.parse(form.dataset.localeCodes || '[]');
    for (const loc of localeCodes) {
      const nameVal = formData.get(`name_${loc}`);
      const slugVal = formData.get(`slug_${loc}`);
      const descVal = formData.get(`description_${loc}`);
      if (nameVal) data[`name_${loc}`] = nameVal;
      if (slugVal) data[`slug_${loc}`] = slugVal;
      if (descVal) data[`description_${loc}`] = descVal;
    }

    try {
      const res = await fetch('/api/plugins/shop/products', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (result.success) {
        window.location.href = '/admin/plugins/shop/products';
      } else {
        if (result.fields) {
          for (const [field, msg] of Object.entries(result.fields)) {
            const el = document.querySelector(`[data-field="${field}"]`);
            if (el) {
              el.textContent = msg as string;
              el.classList.remove('hidden');
            }
          }
        }
        errorDiv.textContent = result.error || 'Failed to create product';
        errorDiv.classList.remove('hidden');
      }
    } catch (err) {
      errorDiv.textContent = 'Network error. Please try again.';
      errorDiv.classList.remove('hidden');
    }
  });
</script>

