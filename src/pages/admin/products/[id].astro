---
// Admin: edit product
// Route: /admin/plugins/shop/products/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import {
  db, eq,
  products, categories, translations, product_prices, product_images,
  sql as dbSql,
  shop_settings,
} from 'astro:db';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';
import RichTextEditor from '../../../components/admin/RichTextEditor.astro';
import ImageUpload from '../../../components/admin/ImageUpload.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const { id } = Astro.params;

const [product] = await db.select().from(products).where(eq(products.id, id));
if (!product) {
  return Astro.redirect('/admin/plugins/shop/products');
}

const catList = await db.select().from(categories).orderBy(categories.name);
const catOptions = catList.map(c => ({ value: c.id, label: c.name }));

// Fetch translations
const transRows = await db.select().from(translations).where(
  dbSql`${translations.entity_type} = 'product' AND ${translations.entity_id} = ${id}`
);

// Fetch prices
const priceRows = await db.select().from(product_prices).where(
  dbSql`${product_prices.product_id} = ${id}`
);

// Fetch images
const imageRows = await db.select().from(product_images)
  .where(eq(product_images.product_id, id))
  .orderBy(product_images.sort_order);

// Fetch locales from settings
const localesResult = await db.run(
  dbSql`SELECT ${shop_settings.value} FROM ${shop_settings} WHERE ${shop_settings.key} = 'locales' LIMIT 1`
);
let locales: { code: string; name: string; isDefault: boolean }[] = [];
if (localesResult.rows.length > 0) {
  try {
    locales = JSON.parse((localesResult.rows[0] as any).value);
  } catch {}
}
const defaultLocale = locales.find(l => l.isDefault)?.code || 'ro';
const otherLocales = locales.filter(l => !l.isDefault);

// Fetch currencies from settings
const currenciesResult = await db.run(
  dbSql`SELECT ${shop_settings.value} FROM ${shop_settings} WHERE ${shop_settings.key} = 'currencies' LIMIT 1`
);
let currencies: { code: string; name: string; isDefault: boolean }[] = [];
if (currenciesResult.rows.length > 0) {
  try {
    currencies = JSON.parse((currenciesResult.rows[0] as any).value);
  } catch {}
}

// Map existing translations by locale
const translationByLocale: Record<string, any> = {};
for (const t of transRows as any[]) {
  translationByLocale[t.locale] = t;
}
---

<AdminLayout title={`Edit: ${product.name}`} currentPath="/admin/plugins/shop/products" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Products', href: '/admin/plugins/shop/products' },
    { label: `Edit: ${product.name}` },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">Edit: {product.name}</h1>
      <p class="text-base-content/60 text-xs font-mono">ID: {product.id}</p>
    </div>
    <a href="/admin/plugins/shop/products" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="product-form" class="space-y-6" data-product-id={product.id} data-default-locale={defaultLocale} data-locale-codes={JSON.stringify(otherLocales.map(l => l.code))}>

        <!-- Section: General -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">General</h4>
            <div class="grid grid-cols-2 gap-4">
              <TextField name="sku" label="SKU" value={product.sku || ''} />
              <SelectField name="type" label="Type" value={product.type} required options={[
                { value: 'physical', label: 'Physical' },
                { value: 'digital', label: 'Digital' },
              ]} />
              <SelectField name="category_id" label="Category" value={product.category_id || ''} placeholder="None" options={catOptions} />
              <TextField name="vat_rate" label="VAT Rate" type="number" step="0.01" min="0" max="1" value={product.vat_rate || ''} />
              <TextField name="stock" label="Stock" type="number" min="0" value={product.stock || ''} />
              <div class="flex items-end pb-2">
                <CheckboxField name="active" label="Active" checked={product.active} />
              </div>
            </div>
          </div>
        </div>

        <!-- Section: Content (locales from settings) -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Content</h4>
            <div class="space-y-6">

              <!-- Default locale -->
              <div>
                <h5 class="font-medium text-sm mb-3">{defaultLocale.toUpperCase()} (default)</h5>
                <div class="space-y-4">
                  <TextField name="name" label={`Name (${defaultLocale.toUpperCase()})`} value={product.name} required />
                  <TextField name="slug" label={`Slug (${defaultLocale.toUpperCase()})`} value={product.slug} required />
                  <RichTextEditor name="description" label={`Description (${defaultLocale.toUpperCase()})`} value={product.description || ''} />
                </div>
              </div>

              <!-- Other locales -->
              {otherLocales.map(locale => {
                const t = translationByLocale[locale.code];
                return (
                  <div class="border-t border-base-300 pt-4">
                    <h5 class="font-medium text-sm mb-3">{locale.name} ({locale.code.toUpperCase()})</h5>
                    <div class="space-y-4">
                      <TextField name={`name_${locale.code}`} label={`Name (${locale.code.toUpperCase()})`} value={t?.name || ''} />
                      <TextField name={`slug_${locale.code}`} label={`Slug (${locale.code.toUpperCase()})`} value={t?.slug || ''} />
                      <RichTextEditor name={`description_${locale.code}`} label={`Description (${locale.code.toUpperCase()})`} value={t?.description || ''} />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Section: Images -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Images</h4>
            <ImageUpload
              productId={product.id}
              existingFiles={(imageRows as any[]).map(img => ({
                id: img.id,
                url: img.url,
                alt: img.alt || '',
                sort_order: img.sort_order,
              }))}
            />
          </div>
        </div>

        <!-- Section: Prices -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Prices</h4>
            <div class="overflow-x-auto">
              <table class="table table-zebra w-full">
                <thead>
                  <tr><th>Currency</th><th>Price (net)</th><th /></tr>
                </thead>
                <tbody id="prices-table-body">
                  {(priceRows as any[]).map(p => (
                    <tr data-price-id={p.id}>
                      <td><code class="text-sm">{p.currency}</code></td>
                      <td class="text-right font-mono">{p.price_net}</td>
                      <td>
                        <button type="button" class="btn btn-ghost btn-xs text-error delete-price" data-id={p.id}>×</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="mt-3">
              <button type="button" class="btn btn-sm btn-outline" id="open-price-modal">Add Price</button>
            </div>
          </div>
        </div>

        <!-- Section: Attributes -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Attributes</h4>
            <div id="attributes-list" class="space-y-2 mb-4">
              <p class="text-base-content/60 text-sm">Loading...</p>
            </div>
            <div class="flex gap-2 items-end">
              <div class="form-control flex-1">
                <label class="label"><span class="label-text font-semibold">Attribute</span></label>
                <select id="assign-attribute-select" class="select select-bordered">
                  <option value="">Select an attribute...</option>
                </select>
              </div>
              <div class="form-control w-40">
                <label class="label"><span class="label-text font-semibold">Role</span></label>
                <select id="assign-role-select" class="select select-bordered">
                  <option value="dimension">Dimension</option>
                  <option value="field">Field</option>
                </select>
              </div>
              <div id="assign-options-container" class="form-control w-64 hidden">
                <label class="label"><span class="label-text font-semibold">Offered Options</span></label>
                <select id="assign-options-select" class="select select-bordered select-multiple h-24" multiple>
                </select>
              </div>
              <button type="button" id="assign-attribute-btn" class="btn btn-primary">Assign</button>
            </div>
            <div id="assign-error" class="text-error text-sm mt-2 hidden"></div>
          </div>
        </div>

        <!-- Section: Variants -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Variants</h4>
            <div id="variants-section">
              <p class="text-base-content/60 text-sm">Loading...</p>
            </div>
          </div>
        </div>

        <!-- Section: Custom Fields -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Custom Fields</h4>
            <div id="custom-fields-section" class="space-y-4">
              <p class="text-base-content/60 text-sm">Loading...</p>
            </div>
            <div id="fields-error" class="text-error text-sm mt-2 hidden"></div>
            <div class="flex justify-end mt-4">
              <button type="button" id="save-fields-btn" class="btn btn-primary btn-sm">Save Field Values</button>
            </div>
          </div>
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Price add modal (outside the form to avoid nesting) -->
  <dialog id="price-modal" class="modal">
    <div class="modal-box max-w-sm">
      <h3 class="font-bold text-lg mb-4">Add Price</h3>
      <form id="add-price-form-inner" class="space-y-4">
        <SelectField name="price_currency" label="Currency" required options={
          currencies.map(c => ({ value: c.code, label: `${c.code} — ${c.name}` }))
        } />
        <TextField name="price_net" label="Price (net)" type="number" step="0.01" min="0" required />
        <div id="price-error" class="text-error text-sm hidden"></div>
        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="button" class="btn btn-ghost" onclick="document.getElementById('price-modal').close()">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Price</button>
        </div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
</AdminLayout>

<script>
  // Read product ID and source page from data attribute / URL
  const PRODUCT_ID = document.querySelector('[data-product-id]')?.getAttribute('data-product-id') || '';
  const FROM_PAGE = new URLSearchParams(window.location.search).get('from_page') || '1';
  const productForm = document.getElementById('product-form') as HTMLFormElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;

  productForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const fd = new FormData(e.target as HTMLFormElement);
    const data: Record<string, any> = {
      name: fd.get('name'),
      slug: fd.get('slug'),
      sku: fd.get('sku') || null,
      description: fd.get('description') || null,
      type: fd.get('type'),
      category_id: fd.get('category_id') || null,
      vat_rate: fd.get('vat_rate') ? parseFloat(fd.get('vat_rate') as string) : null,
      stock: fd.get('stock') ? parseInt(fd.get('stock') as string) : null,
      active: fd.get('active') === 'on',
      default_locale: document.getElementById('product-form')?.dataset?.defaultLocale || 'ro',
    };

    // Include all locale fields (name_en, slug_en, description_en, etc.)
    const localeCodes: string[] = JSON.parse(document.getElementById('product-form')?.dataset?.localeCodes || '[]');
    for (const loc of localeCodes) {
      const nameVal = fd.get(`name_${loc}`);
      const slugVal = fd.get(`slug_${loc}`);
      const descVal = fd.get(`description_${loc}`);
      if (nameVal) data[`name_${loc}`] = nameVal;
      if (slugVal) data[`slug_${loc}`] = slugVal;
      if (descVal) data[`description_${loc}`] = descVal;
    }

    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
    });
    const result = await res.json();

    if (result.success) {
      window.location.href = `/admin/plugins/shop/products?page=${FROM_PAGE}`;
    } else {
      formError.textContent = result.error || 'Failed to save';
      formError.classList.remove('hidden');
    }
  });

  // ── Prices: delete ──
  document.querySelectorAll('.delete-price').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this price?')) return;
      const priceId = (btn as HTMLElement).dataset.id!;
      const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/prices`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ priceId }),
      });
      const result = await res.json();
      if (result.success) {
        location.reload();
      } else {
        alert(result.error || 'Failed to delete price');
      }
    });
  });

  // ── Price modal ──
  document.getElementById('open-price-modal')!.addEventListener('click', () => {
    (document.getElementById('price-modal') as HTMLDialogElement).showModal();
  });

  document.getElementById('add-price-form-inner')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target as HTMLFormElement);
    const priceErr = document.getElementById('price-error')!;
    priceErr.classList.add('hidden');

    const currency = fd.get('price_currency') as string;
    const priceNet = parseFloat(fd.get('price_net') as string);

    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/prices`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prices: [{ product_id: PRODUCT_ID, variant_id: null, currency, price_net: priceNet }] }),
    });
    const result = await res.json();
    if (result.success) {
      (document.getElementById('price-modal') as HTMLDialogElement).close();
      location.reload();
    } else {
      priceErr.textContent = result.error || 'Failed to add price';
      priceErr.classList.remove('hidden');
    }
  });

  // ── Attributes Section ──
  const assignSelect = document.getElementById('assign-attribute-select') as HTMLSelectElement;
  const roleSelect = document.getElementById('assign-role-select') as HTMLSelectElement;
  const optionsContainer = document.getElementById('assign-options-container') as HTMLDivElement;
  const optionsSelect = document.getElementById('assign-options-select') as HTMLSelectElement;
  const assignBtn = document.getElementById('assign-attribute-btn') as HTMLButtonElement;
  const assignError = document.getElementById('assign-error') as HTMLDivElement;

  // Fetch available attributes (not yet assigned)
  async function loadAvailableAttributes() {
    const [allRes, assignedRes] = await Promise.all([
      fetch('/api/plugins/shop/attributes'),
      fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attributes`),
    ]);
    const allData = await allRes.json();
    const assignedData = await assignedRes.json();

    const assignedIds = new Set((assignedData.data || []).map((a: any) => a.attribute_id));
    const available = (allData.data || []).filter((a: any) => !assignedIds.has(a.id));

    assignSelect.innerHTML = '<option value="">Select an attribute...</option>';
    for (const attr of available) {
      const opt = document.createElement('option');
      opt.value = attr.id;
      opt.textContent = `${attr.name} (${attr.type})`;
      opt.dataset.type = attr.type;
      assignSelect.appendChild(opt);
    }
  }

  // Load assigned attributes
  async function loadAssignedAttributes() {
    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attributes`);
    const data = await res.json();
    const list = document.getElementById('attributes-list') as HTMLDivElement;

    if (!data.data || data.data.length === 0) {
      list.innerHTML = '<p class="text-base-content/60 text-sm">No attributes assigned yet.</p>';
      return;
    }

    list.innerHTML = data.data.map((a: any) => `
      <div class="flex items-center gap-3 p-2 bg-base-200 rounded" data-assignment-id="${a.id}">
        <span class="font-medium flex-1">${a.attribute_name}</span>
        <span class="badge ${a.role === 'dimension' ? 'badge-primary' : 'badge-ghost'} badge-sm">${a.role}</span>
        <span class="text-sm text-base-content/60">${a.attribute_type}</span>
        <button type="button" class="btn btn-xs btn-error ghost" data-remove-assignment="${a.id}">×</button>
      </div>
    `).join('');

    // Wire remove buttons
    list.querySelectorAll('[data-remove-assignment]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const assignmentId = (btn as HTMLElement).dataset.removeAssignment!;
        if (!confirm('Remove this attribute assignment?')) return;

        const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attributes/${assignmentId}`, {
          method: 'DELETE',
        });
        const result = await res.json();
        if (result.success) {
          loadAssignedAttributes();
          loadAvailableAttributes();
          loadCustomFields();
        } else {
          alert(result.error || 'Failed to remove assignment');
        }
      });
    });
  }

  // Toggle options container based on role
  roleSelect.addEventListener('change', async () => {
    if (roleSelect.value === 'dimension') {
      optionsContainer.classList.remove('hidden');
      // Load options for selected attribute
      const attrId = assignSelect.value;
      if (attrId) {
        const res = await fetch(`/api/plugins/shop/attributes/${attrId}/options`);
        const data = await res.json();
        optionsSelect.innerHTML = (data.data || []).map((o: any) =>
          `<option value="${o.id}">${o.label || o.value}</option>`
        ).join('');
      }
    } else {
      optionsContainer.classList.add('hidden');
    }
  });

  // Assign attribute
  assignBtn.addEventListener('click', async () => {
    assignError.classList.add('hidden');
    const attrId = assignSelect.value;
    if (!attrId) {
      assignError.textContent = 'Select an attribute';
      assignError.classList.remove('hidden');
      return;
    }

    const body: Record<string, any> = {
      attribute_id: attrId,
      role: roleSelect.value,
    };

    if (roleSelect.value === 'dimension') {
      const selected = Array.from((optionsSelect as HTMLSelectElement).selectedOptions).map(o => o.value);
      if (selected.length === 0) {
        assignError.textContent = 'Select at least one option for dimension';
        assignError.classList.remove('hidden');
        return;
      }
      body.offered_option_ids = selected;
    }

    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attributes`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const result = await res.json();
    if (result.success) {
      loadAssignedAttributes();
      loadAvailableAttributes();
      loadCustomFields();
      loadVariants();
    } else {
      assignError.textContent = result.error || 'Failed to assign attribute';
      assignError.classList.remove('hidden');
    }
  });

  // ── Variants Section ──
  async function loadVariants() {
    const section = document.getElementById('variants-section') as HTMLDivElement;

    // Check if product has dimension assignments
    const attrRes = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attributes`);
    const attrData = await attrRes.json();
    const dimensions = (attrData.data || []).filter((a: any) => a.role === 'dimension');

    // Fetch existing variants
    const varRes = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/variants`);
    const varData = await varRes.json();
    const variants = varData.data || [];

    let html = '';
    if (dimensions.length > 0) {
      html += '<button type="button" id="generate-variants-btn" class="btn btn-sm btn-outline mb-4">Generate Variants</button>';
    }

    if (variants.length > 0) {
      html += '<div class="overflow-x-auto"><table class="table w-full"><thead><tr><th>SKU</th><th>Stock</th><th>Active</th><th>Attributes</th><th class="text-right">Actions</th></tr></thead><tbody>';
      for (const v of variants) {
        const attrLabels = (v.attributes || []).map((a: any) => `${a.attribute_name}: ${a.value}`).join(', ');
        html += `<tr>
          <td class="font-mono text-sm">${v.sku || '—'}</td>
          <td>${v.stock ?? '—'}</td>
          <td>${v.active ? '✓' : '✗'}</td>
          <td class="text-sm">${attrLabels || '—'}</td>
          <td class="text-right">
            <button type="button" class="btn btn-sm btn-ghost" data-edit-variant="${v.id}">Edit</button>
            <button type="button" class="btn btn-sm btn-error ghost" data-delete-variant="${v.id}">×</button>
          </td>
        </tr>`;
      }
      html += '</tbody></table></div>';
    } else {
      html += '<p class="text-base-content/60 text-sm">No variants yet.</p>';
    }

    section.innerHTML = html;

    // Wire generate button
    const genBtn = document.getElementById('generate-variants-btn');
    if (genBtn) {
      genBtn.addEventListener('click', () => openGenerateModal(dimensions));
    }

    // Wire edit/delete buttons
    section.querySelectorAll('[data-edit-variant]').forEach(btn => {
      btn.addEventListener('click', () => openVariantEditModal((btn as HTMLElement).dataset.editVariant!));
    });
    section.querySelectorAll('[data-delete-variant]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const variantId = (btn as HTMLElement).dataset.deleteVariant!;
        if (!confirm('Delete this variant?')) return;
        const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/variants/${variantId}`, { method: 'DELETE' });
        const result = await res.json();
        if (result.success) loadVariants();
        else alert(result.error || 'Failed to delete variant');
      });
    });
  }

  // Generate variants modal
  async function openGenerateModal(dimensions: any[]) {
    const dialog = document.createElement('dialog');
    dialog.className = 'modal';
    dialog.innerHTML = `
      <div class="modal-box max-w-4xl">
        <h3 class="font-bold text-lg mb-4">Generate Variants</h3>
        <p class="text-sm text-base-content/60 mb-4">Check the combinations you want to create. Auto-SKU is based on product slug + option values.</p>
        <div id="combinations-list" class="overflow-x-auto max-h-96 overflow-y-auto mb-4"></div>
        <div class="flex justify-end gap-2">
          <button type="button" class="btn btn-ghost" onclick="this.closest('dialog').close()">Cancel</button>
          <button type="button" id="submit-variants" class="btn btn-primary">Create Selected</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    `;
    document.body.appendChild(dialog);
    dialog.showModal();

    // Compute Cartesian product
    const combos = cartesianProduct(dimensions.map(d => d.offered_options || []));
    const productSlug = product.slug || '';
    const container = dialog.querySelector('#combinations-list') as HTMLDivElement;

    container.innerHTML = '<table class="table w-full"><thead><tr><th>Select</th>' +
      dimensions.map(d => `<th>${d.attribute_name}</th>`).join('') +
      '<th>SKU</th><th>Stock</th></tr></thead><tbody>' +
      combos.map((c, i) => {
        const optionValues = c.map(o => o.value).join('-').toLowerCase();
        const autoSku = `${productSlug}-${optionValues}`;
        return `<tr>
          <td><input type="checkbox" class="checkbox" data-combo-idx="${i}" checked /></td>
          ${dimensions.map((d, di) => `<td class="text-sm">${c[di].label || c[di].value}</td>`).join('')}
          <td><input type="text" class="input input-sm input-bordered w-40" data-combo-sku="${i}" value="${autoSku}" /></td>
          <td><input type="number" class="input input-sm input-bordered w-20" data-combo-stock="${i}" value="0" min="0" /></td>
        </tr>`;
      }).join('') +
      '</tbody></table>';

    dialog.querySelector('#submit-variants')!.addEventListener('click', async () => {
      const selected = Array.from(container.querySelectorAll('input[data-combo-idx]:checked')).map(cb => parseInt(cb.dataset.comboIdx!));
      const combinations = selected.map(idx => {
        const option_ids = combos[idx].map((o: any) => o.id);
        const sku = (container.querySelector(`input[data-combo-sku="${idx}"]`) as HTMLInputElement)?.value || '';
        const stock = parseInt((container.querySelector(`input[data-combo-stock="${idx}"]`) as HTMLInputElement)?.value || '0');
        return { option_ids, sku, stock };
      });

      const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/variants`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ combinations }),
      });
      const result = await res.json();
      if (result.success) {
        dialog.close();
        loadVariants();
      } else {
        alert(result.error || 'Failed to create variants');
      }
    });
  }

  // Variant edit modal
  async function openVariantEditModal(variantId: string) {
    const dialog = document.createElement('dialog');
    dialog.className = 'modal';
    dialog.innerHTML = `
      <div class="modal-box">
        <h3 class="font-bold text-lg mb-4">Edit Variant</h3>
        <div class="space-y-4">
          <div class="form-control"><label class="label"><span class="label-text">SKU</span></label><input type="text" id="edit-variant-sku" class="input input-bordered" /></div>
          <div class="form-control"><label class="label"><span class="label-text">Stock</span></label><input type="number" id="edit-variant-stock" class="input input-bordered" min="0" /></div>
          <div class="form-control"><label class="label cursor-pointer justify-start"><input type="checkbox" id="edit-variant-active" class="checkbox" /><span class="label-text ml-2">Active</span></label></div>
        </div>
        <div class="flex justify-end gap-2 mt-6">
          <button type="button" class="btn btn-ghost" onclick="this.closest('dialog').close()">Cancel</button>
          <button type="button" id="save-variant" class="btn btn-primary">Save</button>
        </div>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    `;
    document.body.appendChild(dialog);
    dialog.showModal();

    // Fetch variant data
    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/variants`);
    const data = await res.json();
    const variant = (data.data || []).find((v: any) => v.id === variantId);
    if (!variant) {
      dialog.close();
      return;
    }

    (dialog.querySelector('#edit-variant-sku') as HTMLInputElement).value = variant.sku || '';
    (dialog.querySelector('#edit-variant-stock') as HTMLInputElement).value = variant.stock ?? '';
    (dialog.querySelector('#edit-variant-active') as HTMLInputElement).checked = variant.active;

    dialog.querySelector('#save-variant')!.addEventListener('click', async () => {
      const body: Record<string, any> = {
        sku: (dialog.querySelector('#edit-variant-sku') as HTMLInputElement).value || null,
        stock: parseInt((dialog.querySelector('#edit-variant-stock') as HTMLInputElement).value) || null,
        active: (dialog.querySelector('#edit-variant-active') as HTMLInputElement).checked,
      };

      const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/variants/${variantId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const result = await res.json();
      if (result.success) {
        dialog.close();
        loadVariants();
      } else {
        alert(result.error || 'Failed to update variant');
      }
    });
  }

  // ── Custom Fields Section ──
  async function loadCustomFields() {
    const section = document.getElementById('custom-fields-section') as HTMLDivElement;
    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attribute-values`);
    const data = await res.json();

    if (!data.data || data.data.length === 0) {
      section.innerHTML = '<p class="text-base-content/60 text-sm">No field attributes assigned. Add field attributes in the Attributes section above.</p>';
      return;
    }

    section.innerHTML = data.data.map((f: any) => {
      let input = '';
      switch (f.attribute_type) {
        case 'text':
          input = `<input type="text" class="input input-bordered" data-field-value="${f.assignment_id}" value="${f.value || ''}" />`;
          break;
        case 'number':
          input = `<input type="number" class="input input-bordered" data-field-value="${f.assignment_id}" value="${f.value || ''}" />`;
          break;
        case 'boolean':
          input = `<input type="checkbox" class="checkbox" data-field-value="${f.assignment_id}" ${f.value ? 'checked' : ''} />`;
          break;
        case 'select':
          input = `<select class="select select-bordered" data-field-value="${f.assignment_id}"><option value="">Select...</option></select>`;
          break;
        default:
          input = `<input type="text" class="input input-bordered" data-field-value="${f.assignment_id}" value="${f.value || ''}" />`;
      }
      return `<div class="form-control">
        <label class="label"><span class="label-text">${f.attribute_name}</span></label>
        ${input}
      </div>`;
    }).join('');
  }

  // Save custom fields
  document.getElementById('save-fields-btn')!.addEventListener('click', async () => {
    const fieldsError = document.getElementById('fields-error') as HTMLDivElement;
    fieldsError.classList.add('hidden');

    const values: any[] = [];
    document.querySelectorAll('[data-field-value]').forEach(el => {
      const assignmentId = el.dataset.fieldValue!;
      let value: any;
      if (el instanceof HTMLInputElement && el.type === 'checkbox') {
        value = { assignment_id: assignmentId, value_boolean: el.checked };
      } else if (el instanceof HTMLInputElement && el.type === 'number') {
        value = { assignment_id: assignmentId, value_number: el.value ? parseFloat(el.value) : null };
      } else {
        value = { assignment_id: assignmentId, value_text: (el as HTMLInputElement | HTMLSelectElement).value || null };
      }
      values.push(value);
    });

    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/attribute-values`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ values }),
    });
    const result = await res.json();
    if (result.success) {
      alert('Field values saved');
    } else {
      fieldsError.textContent = result.error || 'Failed to save field values';
      fieldsError.classList.remove('hidden');
    }
  });

  // Helper: Cartesian product
  function cartesianProduct(arrays: any[]) {
    return arrays.reduce((a, b) => a.flatMap(x => b.map(y => [...x, y])), [[]]);
  }

  // Initialize sections
  loadAvailableAttributes();
  loadAssignedAttributes();
  loadVariants();
  loadCustomFields();
</script>
