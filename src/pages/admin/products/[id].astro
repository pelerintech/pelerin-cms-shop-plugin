---
// Admin: edit product
// Route: /admin/plugins/shop/products/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import {
  db, eq,
  products, categories, translations, product_prices, product_images,
  sql as dbSql,
  shop_settings,
} from 'astro:db';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';
import RichTextEditor from '../../../components/admin/RichTextEditor.astro';
import ImageUpload from '../../../components/admin/ImageUpload.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

const { id } = Astro.params;

const [product] = await db.select().from(products).where(eq(products.id, id));
if (!product) {
  return Astro.redirect('/admin/plugins/shop/products');
}

const catList = await db.select().from(categories).orderBy(categories.name);
const catOptions = catList.map(c => ({ value: c.id, label: c.name }));

// Fetch translations
const transRows = await db.select().from(translations).where(
  dbSql`${translations.entity_type} = 'product' AND ${translations.entity_id} = ${id}`
);

// Fetch prices
const priceRows = await db.select().from(product_prices).where(
  dbSql`${product_prices.product_id} = ${id}`
);

// Fetch images
const imageRows = await db.select().from(product_images)
  .where(eq(product_images.product_id, id))
  .orderBy(product_images.sort_order);

// Fetch locales from settings
const localesResult = await db.run(
  dbSql`SELECT ${shop_settings.value} FROM ${shop_settings} WHERE ${shop_settings.key} = 'locales' LIMIT 1`
);
let locales: { code: string; name: string; isDefault: boolean }[] = [];
if (localesResult.rows.length > 0) {
  try {
    locales = JSON.parse((localesResult.rows[0] as any).value);
  } catch {}
}
const defaultLocale = locales.find(l => l.isDefault)?.code || 'ro';
const otherLocales = locales.filter(l => !l.isDefault);

// Fetch currencies from settings
const currenciesResult = await db.run(
  dbSql`SELECT ${shop_settings.value} FROM ${shop_settings} WHERE ${shop_settings.key} = 'currencies' LIMIT 1`
);
let currencies: { code: string; name: string; isDefault: boolean }[] = [];
if (currenciesResult.rows.length > 0) {
  try {
    currencies = JSON.parse((currenciesResult.rows[0] as any).value);
  } catch {}
}

// Map existing translations by locale
const translationByLocale: Record<string, any> = {};
for (const t of transRows as any[]) {
  translationByLocale[t.locale] = t;
}
---

<AdminLayout title={`Edit: ${product.name}`} currentPath="/admin/plugins/shop/products" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Products', href: '/admin/plugins/shop/products' },
    { label: `Edit: ${product.name}` },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">Edit: {product.name}</h1>
      <p class="text-base-content/60 text-xs font-mono">ID: {product.id}</p>
    </div>
    <a href="/admin/plugins/shop/products" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="product-form" class="space-y-6" data-product-id={product.id} data-default-locale={defaultLocale} data-locale-codes={JSON.stringify(otherLocales.map(l => l.code))}>

        <!-- Section: General -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">General</h4>
            <div class="grid grid-cols-2 gap-4">
              <TextField name="sku" label="SKU" value={product.sku || ''} />
              <SelectField name="type" label="Type" value={product.type} required options={[
                { value: 'physical', label: 'Physical' },
                { value: 'digital', label: 'Digital' },
              ]} />
              <SelectField name="category_id" label="Category" value={product.category_id || ''} placeholder="None" options={catOptions} />
              <TextField name="vat_rate" label="VAT Rate" type="number" step="0.01" min="0" max="1" value={product.vat_rate || ''} />
              <TextField name="stock" label="Stock" type="number" min="0" value={product.stock || ''} />
              <div class="flex items-end pb-2">
                <CheckboxField name="active" label="Active" checked={product.active} />
              </div>
            </div>
          </div>
        </div>

        <!-- Section: Content (locales from settings) -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Content</h4>
            <div class="space-y-6">

              <!-- Default locale -->
              <div>
                <h5 class="font-medium text-sm mb-3">{defaultLocale.toUpperCase()} (default)</h5>
                <div class="space-y-4">
                  <TextField name="name" label={`Name (${defaultLocale.toUpperCase()})`} value={product.name} required />
                  <TextField name="slug" label={`Slug (${defaultLocale.toUpperCase()})`} value={product.slug} required />
                  <RichTextEditor name="description" label={`Description (${defaultLocale.toUpperCase()})`} value={product.description || ''} />
                </div>
              </div>

              <!-- Other locales -->
              {otherLocales.map(locale => {
                const t = translationByLocale[locale.code];
                return (
                  <div class="border-t border-base-300 pt-4">
                    <h5 class="font-medium text-sm mb-3">{locale.name} ({locale.code.toUpperCase()})</h5>
                    <div class="space-y-4">
                      <TextField name={`name_${locale.code}`} label={`Name (${locale.code.toUpperCase()})`} value={t?.name || ''} />
                      <TextField name={`slug_${locale.code}`} label={`Slug (${locale.code.toUpperCase()})`} value={t?.slug || ''} />
                      <RichTextEditor name={`description_${locale.code}`} label={`Description (${locale.code.toUpperCase()})`} value={t?.description || ''} />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- Section: Images -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Images</h4>
            <ImageUpload
              productId={product.id}
              existingFiles={(imageRows as any[]).map(img => ({
                id: img.id,
                url: img.url,
                alt: img.alt || '',
                sort_order: img.sort_order,
              }))}
            />
          </div>
        </div>

        <!-- Section: Prices -->
        <div class="card bg-base-200/50">
          <div class="card-body pb-4">
            <h4 class="font-semibold text-sm uppercase tracking-wide text-base-content/70 mb-4">Prices</h4>
            <div class="overflow-x-auto">
              <table class="table table-zebra w-full">
                <thead>
                  <tr><th>Currency</th><th>Price (net)</th><th /></tr>
                </thead>
                <tbody id="prices-table-body">
                  {(priceRows as any[]).map(p => (
                    <tr data-price-id={p.id}>
                      <td><code class="text-sm">{p.currency}</code></td>
                      <td class="text-right font-mono">{p.price_net}</td>
                      <td>
                        <button type="button" class="btn btn-ghost btn-xs text-error delete-price" data-id={p.id}>×</button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <div class="mt-3">
              <button type="button" class="btn btn-sm btn-outline" id="open-price-modal">Add Price</button>
            </div>
          </div>
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Price add modal (outside the form to avoid nesting) -->
  <dialog id="price-modal" class="modal">
    <div class="modal-box max-w-sm">
      <h3 class="font-bold text-lg mb-4">Add Price</h3>
      <form id="add-price-form-inner" class="space-y-4">
        <SelectField name="price_currency" label="Currency" required options={
          currencies.map(c => ({ value: c.code, label: `${c.code} — ${c.name}` }))
        } />
        <TextField name="price_net" label="Price (net)" type="number" step="0.01" min="0" required />
        <div id="price-error" class="text-error text-sm hidden"></div>
        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="button" class="btn btn-ghost" onclick="document.getElementById('price-modal').close()">Cancel</button>
          <button type="submit" class="btn btn-primary">Add Price</button>
        </div>
      </form>
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
</AdminLayout>

<script>
  // Read product ID and source page from data attribute / URL
  const PRODUCT_ID = document.querySelector('[data-product-id]')?.getAttribute('data-product-id') || '';
  const FROM_PAGE = new URLSearchParams(window.location.search).get('from_page') || '1';
  const productForm = document.getElementById('product-form') as HTMLFormElement;
  const formError = document.getElementById('form-error') as HTMLDivElement;

  productForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.classList.add('hidden');

    const fd = new FormData(e.target as HTMLFormElement);
    const data: Record<string, any> = {
      name: fd.get('name'),
      slug: fd.get('slug'),
      sku: fd.get('sku') || null,
      description: fd.get('description') || null,
      type: fd.get('type'),
      category_id: fd.get('category_id') || null,
      vat_rate: fd.get('vat_rate') ? parseFloat(fd.get('vat_rate') as string) : null,
      stock: fd.get('stock') ? parseInt(fd.get('stock') as string) : null,
      active: fd.get('active') === 'on',
      default_locale: document.getElementById('product-form')?.dataset?.defaultLocale || 'ro',
    };

    // Include all locale fields (name_en, slug_en, description_en, etc.)
    const localeCodes: string[] = JSON.parse(document.getElementById('product-form')?.dataset?.localeCodes || '[]');
    for (const loc of localeCodes) {
      const nameVal = fd.get(`name_${loc}`);
      const slugVal = fd.get(`slug_${loc}`);
      const descVal = fd.get(`description_${loc}`);
      if (nameVal) data[`name_${loc}`] = nameVal;
      if (slugVal) data[`slug_${loc}`] = slugVal;
      if (descVal) data[`description_${loc}`] = descVal;
    }

    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data),
    });
    const result = await res.json();

    if (result.success) {
      window.location.href = `/admin/plugins/shop/products?page=${FROM_PAGE}`;
    } else {
      formError.textContent = result.error || 'Failed to save';
      formError.classList.remove('hidden');
    }
  });

  // ── Prices: delete ──
  document.querySelectorAll('.delete-price').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Delete this price?')) return;
      const priceId = (btn as HTMLElement).dataset.id!;
      const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/prices`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ priceId }),
      });
      const result = await res.json();
      if (result.success) {
        location.reload();
      } else {
        alert(result.error || 'Failed to delete price');
      }
    });
  });

  // ── Price modal ──
  document.getElementById('open-price-modal')!.addEventListener('click', () => {
    (document.getElementById('price-modal') as HTMLDialogElement).showModal();
  });

  document.getElementById('add-price-form-inner')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target as HTMLFormElement);
    const priceErr = document.getElementById('price-error')!;
    priceErr.classList.add('hidden');

    const currency = fd.get('price_currency') as string;
    const priceNet = parseFloat(fd.get('price_net') as string);

    const res = await fetch(`/api/plugins/shop/products/${PRODUCT_ID}/prices`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ prices: [{ product_id: PRODUCT_ID, variant_id: null, currency, price_net: priceNet }] }),
    });
    const result = await res.json();
    if (result.success) {
      (document.getElementById('price-modal') as HTMLDialogElement).close();
      location.reload();
    } else {
      priceErr.textContent = result.error || 'Failed to add price';
      priceErr.classList.remove('hidden');
    }
  });
</script>
