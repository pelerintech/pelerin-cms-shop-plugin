---
// Admin: General shop settings
// Route: /admin/plugins/shop/settings/general
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import Breadcrumbs from '../../../components/admin/Breadcrumbs.astro';
import TextField from '../../../components/admin/TextField.astro';
import SelectField from '../../../components/admin/SelectField.astro';
import CheckboxField from '../../../components/admin/CheckboxField.astro';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout title="General Settings" currentPath="/admin/plugins/shop/settings/general" user={user}>
  <Breadcrumbs items={[
    { label: 'Shop', href: '/admin/plugins/shop' },
    { label: 'Settings', href: '/admin/plugins/shop/settings' },
    { label: 'General' },
  ]} />

  <div class="flex items-center justify-between col-span-12 mb-4">
    <div>
      <h1 class="text-2xl font-bold">General Shop Settings</h1>
      <p class="text-base-content/60">Configuration for the shop</p>
    </div>
    <a href="/admin/plugins/shop" class="btn btn-ghost">Back</a>
  </div>

  <div class="card bg-base-100 shadow-lg col-span-12">
    <div class="card-body">
      <form id="settings-form" class="space-y-6">
        <div class="space-y-4">
          <TextField name="shop_name" label="Shop Name" placeholder="My Shop" />
          <TextField name="order_number_prefix" label="Order Number Prefix" placeholder="ORD" />
          <CheckboxField name="order_number_year" label="Include Year in Order Number" />
          <TextField name="order_number_padding" label="Order Number Padding" type="number" min="1" max="10" value="5" />
          <SelectField name="default_currency" label="Default Currency" placeholder="None" options={[
            { value: 'RON', label: 'RON' },
            { value: 'EUR', label: 'EUR' },
            { value: 'USD', label: 'USD' },
          ]} />
          <SelectField name="default_locale" label="Default Locale" placeholder="None" options={[
            { value: 'ro', label: 'Romanian (ro)' },
            { value: 'en', label: 'English (en)' },
          ]} />
        </div>

        <div id="form-error" class="alert alert-error hidden"></div>
        <div id="form-success" class="alert alert-success hidden"></div>

        <div class="flex justify-end gap-2 pt-4 border-t border-base-200">
          <button type="submit" class="btn btn-primary" id="save-btn">Save Settings</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  var API_URL = '/api/plugins/shop/settings/general';

  async function loadSettings() {
    try {
      var res = await fetch(API_URL);
      var json = await res.json();
      if (json.success && json.data) {
        var form = document.getElementById('settings-form');
        for (var key in json.data) {
          var input = form.elements[key];
          if (!input) continue;
          if (input.type === 'checkbox') {
            input.checked = json.data[key] === 'true' || json.data[key] === true;
          } else {
            if (json.data[key] !== null && json.data[key] !== undefined) {
              input.value = json.data[key];
            }
          }
        }
      }
    } catch (err) {
      console.error('Failed to load settings:', err);
    }
  }

  document.getElementById('settings-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var form = e.target;
    var formData = new FormData(form);
    var body = {};
    formData.forEach(function(value, key) {
      if (value) body[key] = value;
    });
    // Always include checkbox value
    if (form.order_number_year.checked) {
      body.order_number_year = 'true';
    } else {
      body.order_number_year = 'false';
    }

    var errorEl = document.getElementById('form-error');
    var successEl = document.getElementById('form-success');
    var saveBtn = document.getElementById('save-btn');
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';
    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    try {
      var res = await fetch(API_URL, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      var json = await res.json();
      if (json.success) {
        successEl.classList.remove('hidden');
        successEl.textContent = 'Settings saved.';
        setTimeout(function() { successEl.classList.add('hidden'); }, 3000);
        await loadSettings();
      } else {
        errorEl.classList.remove('hidden');
        errorEl.textContent = json.error || 'Failed to save.';
      }
    } catch (err) {
      errorEl.classList.remove('hidden');
      errorEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Settings';
    }
  });

  loadSettings();
</script>
