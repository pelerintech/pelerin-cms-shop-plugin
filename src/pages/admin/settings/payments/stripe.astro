---
// Admin: Stripe payment settings
// Route: /admin/plugins/shop/settings/payments/stripe
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout
  title="Stripe Settings"
  currentPath="/admin/plugins/shop/settings/payments/stripe"
  user={user}
>
  <div class="col-span-12 p-6">
    <h1 class="text-2xl font-bold mb-6">Stripe Payment Settings</h1>

    <form id="stripe-settings-form" class="space-y-4">
      <div class="form-control">
        <label class="label" for="stripe_publishable_key">
          <span class="label-text">Publishable Key</span>
        </label>
        <input
          type="text"
          id="stripe_publishable_key"
          name="stripe_publishable_key"
          class="input input-bordered w-full"
          placeholder="pk_live_..."
        />
      </div>

      <div class="form-control">
        <label class="label" for="stripe_secret_key">
          <span class="label-text">Secret Key</span>
        </label>
        <input
          type="password"
          id="stripe_secret_key"
          name="stripe_secret_key"
          class="input input-bordered w-full"
          placeholder="••••••••"
        />
      </div>

      <div class="form-control">
        <label class="label" for="stripe_webhook_secret">
          <span class="label-text">Webhook Secret</span>
        </label>
        <input
          type="password"
          id="stripe_webhook_secret"
          name="stripe_webhook_secret"
          class="input input-bordered w-full"
          placeholder="whsec_..."
        />
      </div>

      <div class="form-control mt-6">
        <button type="submit" class="btn btn-primary" id="save-btn"> Save Settings </button>
      </div>
    </form>

    <div id="status-message" class="mt-4 hidden"></div>
  </div>
</AdminLayout>

<script>
  const API_URL = '/api/plugins/shop/settings/payments/stripe';

  async function loadSettings() {
    try {
      const res = await fetch(API_URL);
      const json = await res.json();
      if (json.success && json.data) {
        for (const [key, value] of Object.entries(json.data)) {
          const input = document.getElementById(key) as HTMLInputElement;
          if (input && value) {
            input.value = value as string;
          }
        }
      }
    } catch (err) {
      console.error('Failed to load settings:', err);
    }
  }

  document.getElementById('stripe-settings-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const body: Record<string, string> = {};
    formData.forEach((value, key) => {
      if (value) body[key] = value as string;
    });

    const statusEl = document.getElementById('status-message')!;
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      const res = await fetch(API_URL, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const json = await res.json();

      statusEl.classList.remove('hidden');
      if (json.success) {
        statusEl.className = 'mt-4 alert alert-success';
        statusEl.textContent = 'Settings saved successfully.';
        // Reload masked values
        await loadSettings();
      } else {
        statusEl.className = 'mt-4 alert alert-error';
        statusEl.textContent = json.error || 'Failed to save settings.';
      }
    } catch (err: any) {
      statusEl.classList.remove('hidden');
      statusEl.className = 'mt-4 alert alert-error';
      statusEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Settings';
    }
  });

  // Load current settings on page load
  loadSettings();
</script>
