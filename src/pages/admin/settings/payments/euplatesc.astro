---
// Admin: euPlatesc payment settings
// Route: /admin/plugins/shop/settings/payments/euplatesc
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
---

<AdminLayout
  title="euPlatesc Settings"
  currentPath="/admin/plugins/shop/settings/payments/euplatesc"
  user={user}
>
  <div class="col-span-12 p-6">
    <h1 class="text-2xl font-bold mb-6">euPlatesc Payment Settings</h1>

    <form id="euplatesc-settings-form" class="space-y-4">
      <div class="form-control">
        <label class="label" for="euplatesc_merchant_id">
          <span class="label-text">Merchant ID</span>
        </label>
        <input
          type="text"
          id="euplatesc_merchant_id"
          name="euplatesc_merchant_id"
          class="input input-bordered w-full"
          placeholder="Your merchant ID"
        />
      </div>

      <div class="form-control">
        <label class="label" for="euplatesc_secret_key">
          <span class="label-text">Merchant Key</span>
        </label>
        <input
          type="password"
          id="euplatesc_secret_key"
          name="euplatesc_secret_key"
          class="input input-bordered w-full"
          placeholder="••••••••"
        />
      </div>

      <div class="form-control">
        <label class="label" for="euplatesc_ukey">
          <span class="label-text">User Key (ukey)</span>
        </label>
        <input
          type="text"
          id="euplatesc_ukey"
          name="euplatesc_ukey"
          class="input input-bordered w-full"
          placeholder="Your user key for WebServices"
        />
      </div>

      <div class="form-control">
        <label class="label" for="euplatesc_uapi_key">
          <span class="label-text">UAPI Key</span>
        </label>
        <input
          type="password"
          id="euplatesc_uapi_key"
          name="euplatesc_uapi_key"
          class="input input-bordered w-full"
          placeholder="••••••••"
        />
      </div>

      <div class="form-control mt-6">
        <button type="submit" class="btn btn-primary" id="save-btn"> Save Settings </button>
      </div>
    </form>

    <div id="status-message" class="mt-4 hidden"></div>

    <!-- Test / Diagnostic Section -->
    <div class="mt-8 card bg-base-100 shadow-lg">
      <div class="card-body">
        <h2 class="card-title">Test / Diagnostic</h2>
        <p class="text-sm text-base-content/60">
          Verify your euPlatesc integration without creating a real order.
        </p>

        <div class="flex gap-2 mt-2">
          <button type="button" class="btn btn-outline btn-sm" id="test-connection-btn">
            Test Connection
          </button>
          <button type="button" class="btn btn-outline btn-sm" id="test-payment-btn">
            Create Test Payment
          </button>
        </div>

        <div id="test-result" class="mt-4 hidden"></div>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
  const API_URL = '/api/plugins/shop/settings/payments/euplatesc';
  const TEST_CONNECTION_URL = '/api/plugins/shop/settings/payments/euplatesc/test-connection';
  const TEST_PAYMENT_URL = '/api/plugins/shop/settings/payments/euplatesc/test-payment';
  const TEST_RESULT_URL = '/api/plugins/shop/settings/payments/euplatesc/test-result';

  async function loadSettings() {
    try {
      const res = await fetch(API_URL);
      const json = await res.json();
      if (json.success && json.data) {
        for (const [key, value] of Object.entries(json.data)) {
          const input = document.getElementById(key);
          if (input && value) {
            (input as HTMLInputElement).value = value as string;
          }
        }
      }
    } catch (err) {
      console.error('Failed to load settings:', err);
    }
  }

  document.getElementById('euplatesc-settings-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    const body: Record<string, string> = {};
    for (const [key, value] of formData.entries()) {
      if (value) body[key as string] = value as string;
    }

    const statusEl = document.getElementById('status-message')!;
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    saveBtn.disabled = true;
    saveBtn.textContent = 'Saving...';

    try {
      const res = await fetch(API_URL, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      const json = await res.json();

      statusEl.classList.remove('hidden');
      if (json.success) {
        statusEl.className = 'mt-4 alert alert-success';
        statusEl.textContent = 'Settings saved successfully.';
        await loadSettings();
      } else {
        statusEl.className = 'mt-4 alert alert-error';
        statusEl.textContent = json.error || 'Failed to save settings.';
      }
    } catch (err: any) {
      statusEl.classList.remove('hidden');
      statusEl.className = 'mt-4 alert alert-error';
      statusEl.textContent = err.message || 'Network error.';
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = 'Save Settings';
    }
  });

  // Test Connection
  document.getElementById('test-connection-btn')!.addEventListener('click', async () => {
    const resultEl = document.getElementById('test-result')!;
    resultEl.classList.remove('hidden');
    resultEl.className = 'mt-4 alert alert-info';
    resultEl.textContent = 'Testing connection...';

    try {
      const res = await fetch(TEST_CONNECTION_URL, { method: 'POST' });
      const json = await res.json();

      if (json.success) {
        const data = json.data;
        if (data.error) {
          resultEl.className = 'mt-4 alert alert-error';
          resultEl.textContent = `Connection failed: ${data.error}`;
        } else {
          resultEl.className = 'mt-4 alert alert-success';
          resultEl.textContent = `Connection OK — ${data.name || 'Merchant'} (${data.status || 'unknown'})`;
        }
      } else {
        resultEl.className = 'mt-4 alert alert-error';
        resultEl.textContent = json.error || 'Test failed.';
      }
    } catch (err: any) {
      resultEl.className = 'mt-4 alert alert-error';
      resultEl.textContent = err.message || 'Network error.';
    }
  });

  // Create Test Payment
  document.getElementById('test-payment-btn')!.addEventListener('click', async () => {
    const resultEl = document.getElementById('test-result')!;
    resultEl.classList.remove('hidden');
    resultEl.className = 'mt-4 alert alert-info';
    resultEl.textContent = 'Creating test payment...';

    try {
      const res = await fetch(TEST_PAYMENT_URL, { method: 'POST' });
      const json = await res.json();

      if (json.success && json.data?.redirect_url) {
        window.open(json.data.redirect_url, '_blank');
        resultEl.className = 'mt-4 alert alert-success';
        resultEl.textContent =
          'Test payment created. Complete the payment in the new tab. Waiting for IPN...';

        // Poll for IPN result
        let attempts = 0;
        const maxAttempts = 10;
        const pollInterval = setInterval(async () => {
          attempts++;
          try {
            const pollRes = await fetch(TEST_RESULT_URL);
            const pollJson = await pollRes.json();
            if (pollJson.success && pollJson.data) {
              clearInterval(pollInterval);
              const d = pollJson.data;
              resultEl.className = 'mt-4 alert alert-success';
              resultEl.textContent = `IPN received ✓ | action: ${d.action} (${d.action === '0' ? 'approved' : 'failed'}) | MAC valid: ${d.mac_valid} | ep_id: ${d.ep_id || 'N/A'} | amount: ${d.amount} ${d.curr}`;
            } else if (attempts >= maxAttempts) {
              clearInterval(pollInterval);
              resultEl.className = 'mt-4 alert alert-warning';
              resultEl.textContent =
                'No IPN received after 30s. Check webhook URL reachability (ngrok/tunnel required for localhost).';
            }
          } catch {
            if (attempts >= maxAttempts) {
              clearInterval(pollInterval);
              resultEl.className = 'mt-4 alert alert-warning';
              resultEl.textContent = 'Timed out waiting for IPN.';
            }
          }
        }, 3000);
      } else {
        resultEl.className = 'mt-4 alert alert-error';
        resultEl.textContent = json.error || 'Failed to create test payment.';
      }
    } catch (err: any) {
      resultEl.className = 'mt-4 alert alert-error';
      resultEl.textContent = err.message || 'Network error.';
    }
  });

  loadSettings();
</script>
