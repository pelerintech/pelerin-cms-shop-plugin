---
// Admin: Orders list
// Route: /admin/plugins/shop/orders
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';
import { db, orders, sql as dbSql } from 'astro:db';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);

// Parse query params
const url = new URL(Astro.request.url);
const filterStatus = url.searchParams.get('status') || '';
const filterFrom = url.searchParams.get('from') || '';
const filterTo = url.searchParams.get('to') || '';
const filterSearch = url.searchParams.get('search') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const limit = 20;
const offset = (page - 1) * limit;

// Build where clause
const conditions: string[] = [];
if (filterStatus) conditions.push(`o.status = '${filterStatus}'`);
if (filterFrom) conditions.push(`o.created_at >= datetime('${filterFrom}')`);
if (filterTo) conditions.push(`o.created_at <= datetime('${filterTo} 23:59:59')`);
if (filterSearch) {
  const search = filterSearch.replace(/'/g, "''");
  conditions.push(`(o.order_number LIKE '%${search}%' OR o.customer_name LIKE '%${search}%' OR o.customer_email LIKE '%${search}%')`);
}

const whereClause = conditions.length > 0 ? `WHERE ${conditions.join(' AND ')}` : '';

// Fetch orders
const result = await db.run(dbSql`
  SELECT * FROM ${orders} o
  ${dbSql.raw(whereClause)}
  ORDER BY o.created_at DESC
  LIMIT ${limit} OFFSET ${offset}
`);

const orderList = result.rows as any[];

// Count total
const countResult = await db.run(dbSql`
  SELECT COUNT(*) as total FROM ${orders} o
  ${dbSql.raw(whereClause)}
`);
const total = (countResult.rows[0] as any).total as number;
const totalPages = Math.ceil(total / limit);

function statusBadge(status: string) {
  const colors: Record<string, string> = {
    pending: 'badge-ghost',
    awaiting_payment: 'badge-warning',
    paid: 'badge-success',
    processing: 'badge-info',
    shipped: 'badge-primary',
    delivered: 'badge-accent',
    cancelled: 'badge-error',
    refunded: 'badge-error',
  };
  return colors[status] || 'badge-ghost';
}

function statusLabel(status: string): string {
  const labels: Record<string, string> = {
    pending: 'Pending',
    awaiting_payment: 'Awaiting Payment',
    paid: 'Paid',
    processing: 'Processing',
    shipped: 'Shipped',
    delivered: 'Delivered',
    cancelled: 'Cancelled',
    refunded: 'Refunded',
  };
  return labels[status] || status;
}

function buildFilterParams(p: number): string {
  const params = new URLSearchParams();
  if (filterStatus) params.set('status', filterStatus);
  if (filterFrom) params.set('from', filterFrom);
  if (filterTo) params.set('to', filterTo);
  if (filterSearch) params.set('search', filterSearch);
  params.set('page', String(p));
  return params.toString();
}

const hasFilters = filterStatus || filterFrom || filterTo || filterSearch;

// Build export URL with current filters
let exportUrl = '/api/plugins/shop/orders/export';
if (hasFilters) {
  const exportParams = new URLSearchParams();
  if (filterStatus) exportParams.set('status', filterStatus);
  if (filterFrom) exportParams.set('from', filterFrom);
  if (filterTo) exportParams.set('to', filterTo);
  if (filterSearch) exportParams.set('search', filterSearch);
  exportUrl += '?' + exportParams.toString();
}
---

<AdminLayout title="Orders" currentPath="/admin/plugins/shop/orders" user={user}>
  <div class="col-span-12">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">Orders</h1>
      <div class="flex gap-2">
        <a href="/admin/plugins/shop/orders/new" class="btn btn-primary">New Order</a>
        <a href={exportUrl} class="btn btn-outline">Export CSV</a>
      </div>
    </div>

    <!-- Filters -->
    <form method="GET" class="flex gap-4 mb-6 flex-wrap items-end">
      <div class="form-control">
        <label class="label"><span class="label-text">Status</span></label>
        <select name="status" class="select select-bordered">
          <option value="">All</option>
          <option value="pending" selected={filterStatus === 'pending'}>Pending</option>
          <option value="awaiting_payment" selected={filterStatus === 'awaiting_payment'}>Awaiting Payment</option>
          <option value="paid" selected={filterStatus === 'paid'}>Paid</option>
          <option value="processing" selected={filterStatus === 'processing'}>Processing</option>
          <option value="shipped" selected={filterStatus === 'shipped'}>Shipped</option>
          <option value="delivered" selected={filterStatus === 'delivered'}>Delivered</option>
          <option value="cancelled" selected={filterStatus === 'cancelled'}>Cancelled</option>
          <option value="refunded" selected={filterStatus === 'refunded'}>Refunded</option>
        </select>
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text">From</span></label>
        <input type="date" name="from" value={filterFrom} class="input input-bordered" />
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text">To</span></label>
        <input type="date" name="to" value={filterTo} class="input input-bordered" />
      </div>
      <div class="form-control flex-1 min-w-[200px]">
        <label class="label"><span class="label-text">Search</span></label>
        <input type="text" name="search" value={filterSearch} placeholder="Order number, name, email..." class="input input-bordered w-full" />
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text opacity-0">&nbsp;</span></label>
        <button type="submit" class="btn btn-outline">Filter</button>
      </div>
      {hasFilters && (
        <div class="form-control">
          <label class="label"><span class="label-text opacity-0">&nbsp;</span></label>
          <a href="/admin/plugins/shop/orders" class="btn btn-ghost">Clear</a>
        </div>
      )}
    </form>

    <!-- Orders Table -->
    {orderList.length === 0 ? (
      <p class="text-base-content/60">No orders found.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full">
          <thead>
            <tr>
              <th>Order #</th>
              <th>Date</th>
              <th>Customer</th>
              <th>Status</th>
              <th>Total</th>
              <th />
            </tr>
          </thead>
          <tbody>
            {orderList.map((o: any) => (
              <tr>
                <td class="font-medium"><a href={`/admin/plugins/shop/orders/${o.id}`} class="link link-primary">{o.order_number}</a></td>
                <td>{new Date(o.created_at).toLocaleDateString()}</td>
                <td>
                  {o.customer_name}
                  <br />
                  <span class="text-xs text-base-content/50">{o.customer_email}</span>
                </td>
                <td><span class={`badge badge-sm ${statusBadge(o.status)}`}>{statusLabel(o.status)}</span></td>
                <td class="font-mono">{(o.total || 0).toFixed(2)} {o.currency}</td>
                <td>
                  <a href={`/admin/plugins/shop/orders/${o.id}?from_page=${page}`} class="btn btn-ghost btn-xs">View</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Pagination -->
    {totalPages > 1 && (
      <div class="join mt-4">
        {Array.from({ length: totalPages }, (_, i) => i + 1).map(p => (
          <a
            href={`/admin/plugins/shop/orders?${buildFilterParams(p)}`}
            class={`join-item btn btn-sm ${p === page ? 'btn-active' : ''}`}
          >
            {p}
          </a>
        ))}
      </div>
    )}
  </div>
</AdminLayout>
