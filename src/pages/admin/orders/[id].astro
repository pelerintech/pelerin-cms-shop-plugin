---
// Admin: Order detail
// Route: /admin/plugins/shop/orders/[id]
import AdminLayout from 'pelerin:admin-layout';
import { createPluginContext } from 'pelerin:plugin-sdk';

const sdk = createPluginContext();
const user = await sdk.auth.requireAdmin(Astro.request);
const orderId = Astro.params.id;
---

<AdminLayout title={`Order #${orderId}`} currentPath="/admin/plugins/shop/orders" user={user}>
  <div id="order-detail" class="p-6">
    <div class="text-center py-8 text-gray-500">Loading order...</div>
  </div>
</AdminLayout>

<script>
  const orderId = Astro.params.id;

  async function loadOrder() {
    const res = await fetch(`/api/plugins/shop/orders/${orderId}`);
    const json = await res.json();
    if (!json.success) {
      document.getElementById('order-detail').innerHTML = '<div class="text-center py-8 text-error">Order not found</div>';
      return;
    }
    renderOrder(json.data);
  }

  function renderOrder(order) {
    const statusColors = {
      pending: 'badge-ghost', awaiting_payment: 'badge-warning', paid: 'badge-success',
      processing: 'badge-info', shipped: 'badge-primary', delivered: 'badge-accent',
      cancelled: 'badge-error', refunded: 'badge-error',
    };

    // Derive available next statuses
    const transitions = {
      pending: ['awaiting_payment', 'cancelled'],
      awaiting_payment: ['paid', 'cancelled'],
      paid: ['processing', 'cancelled', 'refund_requested'],
      processing: ['shipped', 'cancelled'],
      shipped: ['delivered'],
      delivered: ['refund_requested'],
      refund_requested: ['refunded'],
    };
    const nextStatuses = transitions[order.status] || [];
    const isCancellable = ['pending', 'awaiting_payment', 'paid', 'processing'].includes(order.status);
    const isTerminal = ['cancelled', 'refunded'].includes(order.status);

    // Status history rows
    const historyRows = (order.status_history || []).map(function(h) {
      return '<tr><td>' + new Date(h.created_at).toLocaleString() + '</td>' +
        '<td>' + (h.from_status || '—') + ' → ' + h.to_status + '</td>' +
        '<td class="text-sm text-gray-500">' + (h.note || '') + (h.changed_by ? ' (by ' + h.changed_by + ')' : '') + '</td></tr>';
    }).join('');

    // Items rows
    const itemRows = (order.items || []).map(function(item) {
      return '<tr><td>' + item.product_name + '</td><td>' + (item.sku || '—') + '</td>' +
        '<td>' + item.quantity + '</td><td>' + item.price_net.toFixed(2) + '</td>' +
        '<td>' + (item.vat_rate !== null ? (item.vat_rate * 100).toFixed(0) + '%' : '—') + '</td>' +
        '<td>' + item.price_gross.toFixed(2) + ' ' + order.currency + '</td></tr>';
    }).join('');

    var html = '<div class="flex justify-between items-start mb-6">' +
      '<div><h1 class="text-2xl font-bold">Order ' + order.order_number + '</h1>' +
      '<p class="text-sm text-gray-500">Created: ' + new Date(order.created_at).toLocaleString() + '</p></div>' +
      '<div class="flex items-center gap-3"><span class="badge ' + (statusColors[order.status] || 'badge-ghost') + ' text-lg px-3 py-2">' + order.status + '</span>' +
      (isTerminal ? '' : '<div class="flex gap-2">' +
        (nextStatuses.length > 0 ? '<div class="dropdown dropdown-end"><button class="btn btn-sm btn-outline">Change Status</button><ul class="dropdown-content menu bg-base-200 rounded-box w-52 p-2 shadow">' +
          nextStatuses.map(function(s) { return '<li><a href="#" onclick="changeStatus(\'' + s + '\')">' + s + '</a></li>'; }).join('') +
        '</ul></div>' : '') +
        (isCancellable ? '<button class="btn btn-sm btn-error btn-outline" onclick="cancelOrder()">Cancel</button>' : '') +
        (!isTerminal && order.status !== 'cancelled' ? '<button class="btn btn-sm btn-outline" onclick="showRefund()">Record Refund</button>' : '') +
      '</div>') +
      '</div></div>';

    // Determine if shipping address should be shown (not digital-only orders)
    var showShipping = order.shipping_type !== 'digital';

    // Customer + Addresses
    var addressGridCols = showShipping ? 'md:grid-cols-3' : 'md:grid-cols-2';
    html += '<div class="grid grid-cols-1 ' + addressGridCols + ' gap-6 mb-6">' +
      '<div class="card bg-base-100 shadow"><div class="card-body"><h2 class="card-title text-lg">Customer</h2>' +
      '<p class="font-semibold">' + order.customer_name + '</p>' +
      '<p>' + order.customer_email + '</p>' +
      (order.customer_phone ? '<p>' + order.customer_phone + '</p>' : '') +
      '<p class="text-sm text-gray-500">' + order.customer_type + '</p></div></div>' +
      '<div class="card bg-base-100 shadow"><div class="card-body"><h2 class="card-title text-lg">Billing Address</h2>' +
      '<p>' + order.billing_first_name + ' ' + order.billing_last_name + '</p>' +
      '<p>' + order.billing_address + '</p>' +
      '<p>' + order.billing_city + ', ' + (order.billing_county || '') + ' ' + order.billing_postal_code + '</p>' +
      '<p>' + order.billing_country + '</p>' +
      (order.billing_company ? '<p class="text-sm mt-2">' + order.billing_company + (order.billing_vat_number ? ' — VAT: ' + order.billing_vat_number : '') + '</p>' : '') +
      '</div></div>' +
      (showShipping ? '<div class="card bg-base-100 shadow"><div class="card-body"><h2 class="card-title text-lg">Shipping Address</h2>' +
        (order.shipping_same_as_billing ? '<p class="text-sm text-gray-500 mb-2">Same as billing</p>' : '') +
        '<p>' + (order.shipping_first_name || '—') + ' ' + (order.shipping_last_name || '') + '</p>' +
        '<p>' + (order.shipping_address || '—') + '</p>' +
        '<p>' + (order.shipping_city || '—') + (order.shipping_county ? ', ' + order.shipping_county : '') + ' ' + (order.shipping_postal_code || '') + '</p>' +
        '<p>' + (order.shipping_country || '—') + '</p>' +
        (order.shipping_company ? '<p class="text-sm mt-2">' + order.shipping_company + (order.shipping_vat_number ? ' — VAT: ' + order.shipping_vat_number : '') + '</p>' : '') +
      '</div></div>' : '') +
      '</div>';

    // Items
    html += '<div class="card bg-base-100 shadow mb-6"><div class="card-body"><h2 class="card-title text-lg">Items</h2>' +
      '<table class="table table-sm"><thead><tr><th>Product</th><th>SKU</th><th>Qty</th><th>Price Net</th><th>VAT</th><th>Total</th></tr></thead>' +
      '<tbody>' + (itemRows || '<tr><td colspan="6">No items</td></tr>') + '</tbody></table></div></div>';

    // Totals
    html += '<div class="card bg-base-100 shadow mb-6"><div class="card-body"><h2 class="card-title text-lg">Totals</h2>' +
      '<div class="text-sm space-y-1"><p>Subtotal (net): ' + order.subtotal_net.toFixed(2) + ' ' + order.currency + '</p>' +
      '<p>VAT: ' + order.vat_total.toFixed(2) + ' ' + order.currency + '</p>' +
      '<p>Shipping: ' + order.shipping_cost.toFixed(2) + ' ' + order.currency + '</p>' +
      (order.discount_amount > 0 ? '<p>Discount: -' + order.discount_amount.toFixed(2) + ' ' + order.currency + '</p>' : '') +
      '<p class="font-bold text-lg mt-2">Total: ' + order.total.toFixed(2) + ' ' + order.currency + '</p></div></div></div>';

    // Payment info
    html += '<div class="card bg-base-100 shadow mb-6"><div class="card-body"><h2 class="card-title text-lg">Payment</h2>' +
      '<p>Provider: ' + (order.payment_provider || '—') + ' | Transaction: ' + (order.transaction_id || '—') +
      ' | Voucher: ' + (order.voucher_code || '—') + ' | Referral: ' + (order.referral_code || '—') + '</p>' +
      (order.refund_amount ? '<p class="text-error mt-2">Refunded: ' + order.refund_amount.toFixed(2) + ' ' + order.currency + (order.refund_notes ? ' — ' + order.refund_notes : '') + '</p>' : '') +
      '</div></div>';

    // Status History
    html += '<div class="card bg-base-100 shadow mb-6"><div class="card-body"><h2 class="card-title text-lg">Status History</h2>' +
      '<table class="table table-sm"><thead><tr><th>Date</th><th>Transition</th><th>Note</th></tr></thead>' +
      '<tbody>' + (historyRows || '<tr><td colspan="3">No history</td></tr>') + '</tbody></table></div></div>';

    document.getElementById('order-detail').innerHTML = html;
  }

  window.changeStatus = async function(newStatus) {
    var note = prompt('Note (optional):');
    var res = await fetch('/api/plugins/shop/orders/' + orderId + '/status', {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: newStatus, note: note || null }),
    });
    var json = await res.json();
    if (json.success) { loadOrder(); }
    else { alert(json.error || 'Failed to update status'); }
  };

  window.cancelOrder = async function() {
    if (!confirm('Cancel this order?')) return;
    var res = await fetch('/api/plugins/shop/orders/' + orderId + '/cancel', { method: 'PUT' });
    var json = await res.json();
    if (json.success) { loadOrder(); }
    else { alert(json.error || 'Failed to cancel'); }
  };

  window.showRefund = async function() {
    var amount = prompt('Refund amount:');
    if (!amount) return;
    var notes = prompt('Notes (optional):');
    var res = await fetch('/api/plugins/shop/orders/' + orderId + '/refund', {
      method: 'PUT', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refund_amount: parseFloat(amount), refund_notes: notes || null }),
    });
    var json = await res.json();
    if (json.success) { loadOrder(); }
    else { alert(json.error || 'Failed to record refund'); }
  };

  loadOrder();
</script>